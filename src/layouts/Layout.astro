---
interface Props {
	title: string;
}

const { title } = Astro.props;
import '../styles/global.css';
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta
			name="description"
			content="Alabama web developer building and repairing fast, reliable websites for small businesses."
		/>
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.0.3/dist/fonts/geist-sans/style.css" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/geist@1.0.3/dist/fonts/geist-mono/style.css" />
		<title>{title}</title>
	</head>
	<body class="bg-bgMain text-textPrimary font-sans antialiased overflow-x-hidden selection:bg-primary selection:text-white">
		<slot />

		<script>
			const setupBrutalReveal = () => {
				const observerOptions = {
					root: null,
					rootMargin: '0px',
					threshold: 0.15,
				};

				const observer = new IntersectionObserver((entries, activeObserver) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add('is-visible');
							activeObserver.unobserve(entry.target);
						}
					});
				}, observerOptions);

				document.querySelectorAll('.observe-block').forEach((element) => observer.observe(element));
			};

			const setupBeforeAfterSliders = () => {
				document.querySelectorAll('.before-after-slider').forEach((slider) => {
					const input = slider.querySelector('.slider-input');
					const beforeWrapper = slider.querySelector('.before-image-wrapper');
					const beforeInner = slider.querySelector('.before-inner');
					const sliderLine = slider.querySelector('.slider-line');

					if (!(input instanceof HTMLInputElement) || !beforeWrapper || !(beforeInner instanceof HTMLElement) || !(sliderLine instanceof HTMLElement)) {
						return;
					}

					const updateInnerWidth = () => {
						const sliderWidth = slider.getBoundingClientRect().width;
						beforeInner.style.width = `${sliderWidth}px`;
					};

					const updateSlider = () => {
						beforeWrapper.setAttribute('style', `width: ${input.value}%`);
						sliderLine.style.left = `${input.value}%`;
					};

					input.value = input.getAttribute('value') ?? '50';
					updateInnerWidth();
					updateSlider();
					window.addEventListener('resize', updateInnerWidth);
					window.addEventListener('orientationchange', () => setTimeout(updateInnerWidth, 100));
					input.addEventListener('input', updateSlider);
				});
			};

			const setupBrutalButtonPress = () => {
				const shouldDelayPress =
					window.matchMedia('(hover: none), (pointer: coarse)').matches &&
					!window.matchMedia('(prefers-reduced-motion: reduce)').matches;

				if (!shouldDelayPress) {
					return;
				}

				const pressDelay = 160;

				document.querySelectorAll<HTMLElement>('.btn-brutal').forEach((button) => {
					if (button.dataset.brutalPressReady === 'true') {
						return;
					}

					button.dataset.brutalPressReady = 'true';

					button.addEventListener('click', (event: MouseEvent) => {
						if (event.defaultPrevented || button.classList.contains('is-pressing')) {
							return;
						}

						if (event.metaKey || event.ctrlKey || event.shiftKey || event.altKey) {
							return;
						}

						if (button instanceof HTMLAnchorElement) {
							const href = button.getAttribute('href');

							if (!href || button.target || button.hasAttribute('download')) {
								return;
							}

							event.preventDefault();
							button.classList.add('is-pressing');

							window.setTimeout(() => {
								button.classList.remove('is-pressing');

								if (href.startsWith('#')) {
									const target = document.querySelector(href);
									if (target) {
										target.scrollIntoView({ behavior: 'smooth', block: 'start' });
										window.history.pushState(null, '', href);
										return;
									}
								}

								window.location.href = button.href;
							}, pressDelay);

							return;
						}

						if (button instanceof HTMLButtonElement && button.type === 'submit' && button.form) {
							event.preventDefault();
							button.classList.add('is-pressing');

							window.setTimeout(() => {
								button.classList.remove('is-pressing');
								button.form?.requestSubmit(button);
							}, pressDelay);
						}
					});
				});
			};

			const setupProblemSourceToggles = () => {
				document.querySelectorAll<HTMLButtonElement>('.problem-source-toggle').forEach((toggle) => {
					if (toggle.dataset.sourceToggleReady === 'true') {
						return;
					}

					toggle.dataset.sourceToggleReady = 'true';

					toggle.addEventListener('click', () => {
						const card = toggle.closest('.problem-card');
						const isOpen = card?.classList.toggle('is-source-open') ?? false;

						toggle.setAttribute('aria-expanded', String(isOpen));
						toggle.textContent = isOpen
							? toggle.dataset.openLabel ?? '[ HIDE SOURCE ]'
							: toggle.dataset.closedLabel ?? '[ TAP FOR SOURCE ]';
					});
				});
			};

			const setupBrutalPage = () => {
				setupBrutalReveal();
				setupBeforeAfterSliders();
				setupBrutalButtonPress();
				setupProblemSourceToggles();
			};

			document.addEventListener('astro:page-load', setupBrutalPage);
			if (document.readyState === 'loading') {
				document.addEventListener('DOMContentLoaded', setupBrutalPage);
			} else {
				setupBrutalPage();
			}
		</script>
	</body>
</html>
