---
import { Camera, MapPin, ShieldCheck, SquareCheck } from 'lucide-react';
---

<section id="about" class="w-full px-4 sm:px-8 py-16 lg:py-24 bg-surface brutal-border-b relative z-10">
	<div class="max-w-[1400px] mx-auto grid lg:grid-cols-2 gap-12 lg:gap-20 items-center observe-block">
		<div class="flex flex-col">
			<span class="text-[12px] font-mono font-bold text-primary uppercase tracking-widest block mb-4">[ 05. Guarantee ]</span>
			<h2 class="text-fluid-h2 font-bold uppercase mb-10 leading-none">
				<span class="reveal-overflow"><span class="reveal-text block">A Partner, Not</span></span><br />
				<span class="reveal-overflow"><span class="reveal-text block text-outline">Just A Dev.</span></span>
			</h2>

			<div class="stamp-item shadow-brutal delay-100 bg-bgMain brutal-border p-6 mb-10 flex gap-6 items-center">
				<div class="w-24 h-24 bg-gray-300 brutal-border flex-shrink-0 flex items-center justify-center text-textMuted hover:bg-primary hover:text-white transition-colors duration-300">
					<Camera className="w-10 h-10 opacity-80" />
				</div>
				<div>
					<h3 class="text-[24px] font-bold uppercase mb-1">Andrii</h3>
					<p class="text-[14px] font-mono font-bold text-textSecondary uppercase tracking-widest mb-3">Technical Partner</p>
					<div class="inline-flex items-center gap-2 bg-black text-white px-3 py-1 text-[12px] font-bold uppercase shadow-brutal-sm">
						<MapPin className="w-4 h-4" /> Based in Alabama
					</div>
				</div>
			</div>
		</div>

		<div class="flex flex-col gap-10">
			<div class="stamp-item delay-200 flex flex-col gap-5 border-l-4 border-primary pl-6">
				<div class="flex items-center gap-4 hover:translate-x-2 transition-transform cursor-default">
					<SquareCheck className="w-6 h-6 text-primary" />
					<span class="text-[18px] font-[600]">Structured SOWs & Timelines</span>
				</div>
				<div class="flex items-center gap-4 hover:translate-x-2 transition-transform cursor-default">
					<SquareCheck className="w-6 h-6 text-primary" />
					<span class="text-[18px] font-[600]">Direct Communication</span>
				</div>
				<div class="flex items-center gap-4 hover:translate-x-2 transition-transform cursor-default">
					<SquareCheck className="w-6 h-6 text-primary" />
					<span class="text-[18px] font-[600]">Ongoing Support</span>
				</div>
			</div>

			<div class="stamp-item shadow-brutal delay-300 bg-black text-white brutal-border p-8 sm:p-10 relative mt-6 lg:mt-0">
				<div class="absolute -top-6 right-6 bg-primary text-white border-[3px] border-black p-3 shadow-brutal-sm">
					<ShieldCheck className="w-8 h-8" />
				</div>
				<h3 class="text-[24px] font-bold uppercase mb-4">No-Ghosting Promise</h3>
				<p class="text-[16px] font-[500] text-gray-300 leading-relaxed">
					You'll always know the project status, next steps, and how to reach me. I use clear scopes and regular updates so you're never left guessing.
				</p>
			</div>
		</div>
	</div>
</section>
