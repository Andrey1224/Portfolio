---
import { ShieldCheck, User } from 'lucide-react';
---
<section class="w-full px-5 py-12 lg:py-24 bg-surface border-t border-borderLight lg:rounded-none rounded-t-[32px] mt-[-20px] lg:mt-0 relative z-10">
    <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-20 items-center">
        <!-- Left: Identity Card -->
        <div class="flex justify-center lg:justify-end order-2 lg:order-1">
            <div class="w-full max-w-[380px] bg-surfaceMuted rounded-[24px] border border-borderLight shadow-card overflow-hidden">
                <!-- Placeholder for photo -->
                <div class="w-full aspect-[4/5] bg-surfaceWarm flex flex-col items-center justify-center relative overflow-hidden group">
                    <User className="w-20 h-20 text-textMuted/30 group-hover:scale-110 transition-transform duration-500" />
                    <div class="absolute inset-0 bg-gradient-to-t from-bgMain to-transparent opacity-60"></div>
                </div>
                <div class="p-6 text-center lg:text-left bg-surface">
                    <h3 class="text-[20px] font-bold text-textPrimary mb-1">Andrii</h3>
                    <p class="text-[14px] font-medium text-textSecondary mb-4">Web Developer & Technical Partner</p>
                    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-surfaceMuted border border-borderLight text-textSecondary text-[12px] font-medium">
                        Based in Alabama
                    </div>
                </div>
            </div>
        </div>

        <!-- Right: Content -->
        <div class="flex flex-col items-center lg:items-start text-center lg:text-left order-1 lg:order-2">
            <span class="text-[11px] font-[650] text-primary uppercase tracking-wide mb-2 lg:mb-4 block">The No-Ghosting Guarantee</span>
            <h2 class="text-[28px] lg:text-[40px] font-bold text-textPrimary leading-[1.15] mb-6">A partner, not just a developer.</h2>
            
            <p class="text-[15px] lg:text-[18px] text-textSecondary leading-[1.6] mb-8 lg:mb-10 max-w-[500px]">
                I'm a web developer based in Alabama who partners with small businesses to build, repair, and maintain high-performance websites. No handoffs. No ghosting. Just clear communication, reliable work, and systems built to last.
            </p>

            <div class="bg-primarySoft border border-primary/20 rounded-2xl p-6 lg:p-8 flex gap-4 lg:gap-6 items-start w-full shadow-sm">
                <div class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary flex-shrink-0">
                    <ShieldCheck className="w-6 h-6" />
                </div>
                <div class="text-left">
                    <h3 class="text-[16px] lg:text-[18px] font-[650] text-textPrimary mb-2">No-Ghosting Promise</h3>
                    <p class="text-[14px] lg:text-[15px] text-textSecondary leading-[1.6]">
                        You'll always know the project status, next steps, and how to reach me. I use clear scopes, timelines, and regular updates so you're never left guessing.
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>