---
import { SquareCheck } from 'lucide-react';
---

<section id="about" class="w-full px-4 sm:px-8 py-16 lg:py-32 bg-bgMain brutal-border-b relative z-10 overflow-hidden">
    <div class="max-w-[1400px] mx-auto relative pt-0 lg:pt-10 mb-0 observe-block">
        <!-- The Grid Breaking Photo -->
        <div class="stamp-item delay-200 relative lg:absolute lg:top-[-50px] lg:left-10 z-20 w-[72%] max-w-[260px] sm:max-w-[350px] lg:max-w-[450px] mx-auto lg:mx-0 mb-10 lg:mb-0">
            <div class="relative">
                <img src="/images/PartnerPhoto.jpg" alt="Andrii" class="w-full aspect-[3/4] object-cover border-4 border-black shadow-[6px_6px_0_0_#000] sm:shadow-[8px_8px_0_0_#000] grayscale contrast-125 transform -rotate-3" />
                <!-- Stickers -->
                <div class="absolute -top-5 -right-8 sm:-right-6 bg-[#EF4444] text-white font-black text-[11px] sm:text-[18px] lg:text-[22px] uppercase border-4 border-black px-2 sm:px-3 py-2 transform rotate-6 shadow-[4px_4px_0_0_#000] max-w-[150px] sm:max-w-none leading-tight">WORK WITH ME DIRECTLY</div>
                <div class="absolute -bottom-5 -left-5 bg-warning text-black font-black text-[20px] lg:text-[32px] rounded-full w-20 h-20 lg:w-32 lg:h-32 flex items-center justify-center border-4 border-black transform -rotate-2 shadow-[4px_4px_0_0_#000] leading-none text-center">6+<br>YRS</div>
            </div>
        </div>

        <div class="grid lg:grid-cols-2 gap-12 lg:gap-20">
            <!-- Empty space for the photo to overlap -->
            <div class="hidden lg:block"></div>
            
            <div class="stamp-item delay-100 bg-black text-white border-4 border-black p-6 sm:p-8 md:p-16 relative shadow-[6px_6px_0_0_#000] sm:shadow-[8px_8px_0_0_#000] lg:ml-[-100px] z-10">
                <span class="text-[12px] font-mono font-bold text-primary uppercase tracking-widest block mb-4">[ 05. Guarantee ]</span>
                <h2 class="text-[34px] sm:text-[40px] md:text-[60px] font-black uppercase mb-8 leading-[1.05] md:leading-none">A Partner,<br><span class="text-transparent" style="-webkit-text-stroke: 2px white;">Not Just A Dev.</span></h2>
                
                <h3 class="text-[24px] font-bold uppercase mb-4 text-[#F59E0B]">No-Ghosting Promise</h3>
                <p class="text-[16px] sm:text-[18px] font-[500] text-gray-300 leading-relaxed mb-8 max-w-md">
                    You'll always know the project status, next steps, and how to reach me. I use clear scopes and regular updates so you're never left guessing.
                </p>
                
                <div class="flex flex-col gap-4 font-mono font-bold text-[14px] sm:text-[16px]">
                    <div class="flex items-center gap-4"><SquareCheck className="text-primary w-6 h-6 flex-shrink-0" /> 6+ Years Experience</div>
                    <div class="flex items-center gap-4"><SquareCheck className="text-primary w-6 h-6 flex-shrink-0" /> Based in Alabama</div>
                    <div class="flex items-center gap-4"><SquareCheck className="text-primary w-6 h-6 flex-shrink-0" /> Full-Stack Engineering</div>
                </div>
            </div>
        </div>
    </div>
</section>
