---
import { MapPin, ArrowRight, ChevronDown, LayoutTemplate, Smartphone, Zap } from 'lucide-react';
---
<section id="work" class="w-full px-5 py-12 lg:py-20 bg-[#F8FAFC] border-t border-borderLight flex flex-col items-center">
    <div class="max-w-7xl mx-auto w-full">
    <div class="text-center mb-10 lg:mb-16 reveal-section">
        <span class="text-[11px] font-[650] text-primary uppercase tracking-wide mb-2 lg:mb-4 block">The Proof</span>
        <h2 class="text-[28px] lg:text-[40px] font-bold text-textPrimary">Case Studies</h2>
    </div>

    <div class="flex flex-col gap-6 w-full mb-10 lg:mb-12">
        <!-- Главный кейс -->
        <div class="bg-surface border border-borderLight rounded-[32px] p-6 lg:p-10 shadow-elevated flex flex-col lg:flex-row gap-8 lg:gap-12 items-center reveal-card group">
            <div class="w-full lg:w-1/2 flex flex-col items-start order-2 lg:order-1">
                <div class="flex items-center gap-3 mb-4 lg:mb-6">
                    <div class="w-8 h-8 rounded bg-primary text-white flex items-center justify-center text-[14px] font-bold shadow-sm">1</div>
                    <h3 class="text-[20px] lg:text-[28px] font-bold leading-tight text-textPrimary">Veterinary Clinic Modernization</h3>
                </div>
                
                <div class="flex items-center gap-2 mb-4 overflow-hidden">
                    <span class="text-[20px] lg:text-[24px] font-bold text-success animate-[slideDown_0.5s_ease-out]">100 / 100</span>
                    <span class="text-[13px] lg:text-[14px] text-textSecondary font-medium uppercase tracking-wide">Performance Score</span>
                </div>
                <p class="text-[15px] lg:text-[16px] text-textSecondary leading-[1.6] mb-8">
                    A faster, more trustworthy website designed to improve local visibility and make patient inquiries easier to manage.
                </p>
                <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center w-full gap-4 pt-6 border-t border-borderLight">
                    <div class="flex items-center gap-2 text-[13px] lg:text-[14px] font-medium text-textMuted bg-surfaceMuted px-3 py-1.5 rounded-full border border-borderLight">
                        <MapPin className="w-4 h-4" /> Local Healthcare (AL)
                    </div>
                    <a href="#" class="text-[15px] font-[650] text-primary flex items-center gap-1.5 hover:text-primaryHover transition-colors group-hover:underline">
                        View Case Study <ArrowRight className="w-4 h-4" />
                    </a>
                </div>
            </div>
            
            <div class="w-full lg:w-1/2 order-1 lg:order-2">
                <!-- Interactive Before/After CSS Representation -->
                <div class="w-full aspect-[4/3] relative rounded-[24px] overflow-hidden bg-surfaceMuted border border-borderLight shadow-inner group/slider cursor-col-resize">
                    <!-- Before state -->
                    <div class="absolute inset-0 bg-surfaceWarm flex items-center justify-center p-6 text-textMuted">
                         <div class="w-full h-full border-2 border-dashed border-borderStrong rounded-xl flex flex-col items-center justify-center bg-surface/50 opacity-60">
                             <div class="w-3/4 h-4 bg-borderStrong rounded mb-4"></div>
                             <div class="w-1/2 h-4 bg-borderStrong rounded mb-4"></div>
                             <div class="w-1/4 h-8 bg-borderStrong rounded"></div>
                         </div>
                         <span class="absolute top-4 left-4 bg-surface/80 backdrop-blur px-3 py-1 rounded-md text-[11px] font-bold uppercase text-textMuted border border-borderLight shadow-sm">Before (Slow)</span>
                    </div>
                    
                    <!-- After state (reveals on hover using clip-path) -->
                    <div class="absolute inset-0 bg-primarySoft flex items-center justify-center p-6 [clip-path:polygon(50%_0,100%_0,100%_100%,50%_100%)] group-hover/slider:[clip-path:polygon(0_0,100%_0,100%_100%,0_100%)] transition-all duration-700 ease-out z-10">
                        <div class="w-full h-full bg-surface rounded-xl shadow-lg border border-primary/20 flex flex-col overflow-hidden relative">
                             <div class="h-8 bg-surfaceMuted border-b border-borderLight flex items-center px-3 gap-1.5">
                                 <div class="w-2 h-2 rounded-full bg-primary/30"></div>
                                 <div class="w-2 h-2 rounded-full bg-primary/30"></div>
                                 <div class="w-2 h-2 rounded-full bg-primary/30"></div>
                             </div>
                             <div class="p-4 flex-grow flex flex-col items-center justify-center">
                                 <div class="w-12 h-12 bg-primary/10 rounded-full mb-3 flex items-center justify-center text-primary"><Zap className="w-6 h-6"/></div>
                                 <div class="w-1/2 h-3 bg-primary/20 rounded mb-2"></div>
                                 <div class="w-1/3 h-3 bg-textSecondary/20 rounded"></div>
                             </div>
                        </div>
                        <span class="absolute top-4 right-4 bg-success/90 backdrop-blur px-3 py-1 rounded-md text-[11px] font-bold uppercase text-white border border-success shadow-sm">After (Lightning Fast)</span>
                    </div>
                    
                    <!-- Slider handle (visual only) -->
                    <div class="absolute inset-y-0 left-1/2 w-1 bg-white shadow-[0_0_10px_rgba(0,0,0,0.2)] z-20 group-hover/slider:left-0 transition-all duration-700 ease-out flex items-center justify-center -ml-0.5">
                        <div class="w-6 h-6 bg-white rounded-full shadow-md border border-borderLight flex items-center justify-center">
                            <div class="w-0.5 h-3 bg-borderStrong mx-0.5"></div>
                            <div class="w-0.5 h-3 bg-borderStrong mx-0.5"></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Secondary Cases -->
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 w-full">
            <!-- Case 2 -->
            <div class="bg-surface border border-borderLight rounded-[24px] p-6 shadow-subtle hover-lift reveal-card flex flex-col">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-7 h-7 rounded bg-primarySoft text-primary flex items-center justify-center text-[13px] font-bold">2</div>
                    <h3 class="text-[18px] font-bold leading-tight text-textPrimary">Senior Accessibility: Walk-In Baths</h3>
                </div>
                
                <div class="flex flex-col mb-6 flex-grow">
                    <div class="flex gap-2 mb-4">
                        <span class="px-2 py-1 rounded-md bg-accent/10 text-accent text-[10px] font-bold uppercase tracking-wider">UX</span>
                        <span class="px-2 py-1 rounded-md bg-primary/10 text-primary text-[10px] font-bold uppercase tracking-wider">Conversion</span>
                    </div>
                    <p class="text-[14px] text-textSecondary leading-[1.6] mb-4">
                        Improved clarity for an older audience with accessibility-focused UI and simplified inquiry flow.
                    </p>
                    <div class="flex items-center gap-2 mt-auto pt-4">
                        <span class="text-[18px] font-bold text-success">2x</span>
                        <span class="text-[12px] text-textSecondary font-medium leading-tight">Increase in clarity<br>leading to inquiries.</span>
                    </div>
                </div>
                
                <div class="flex justify-between items-center border-t border-borderLight pt-4 mt-auto">
                    <div class="flex items-center gap-1.5 text-[12px] text-textMuted font-medium">
                        <MapPin className="w-3.5 h-3.5" /> High-Ticket Service
                    </div>
                    <a href="#" class="text-[14px] font-[650] text-primary flex items-center gap-1.5 hover:text-primaryHover transition-colors">
                        Case Study <ArrowRight className="w-3.5 h-3.5" />
                    </a>
                </div>
            </div>

            <!-- Case 3 -->
            <div class="bg-surface border border-borderLight rounded-[24px] p-6 shadow-subtle hover-lift reveal-card reveal-delay-1 flex flex-col">
                <div class="flex items-center gap-3 mb-4">
                    <div class="w-7 h-7 rounded bg-primarySoft text-primary flex items-center justify-center text-[13px] font-bold">3</div>
                    <h3 class="text-[18px] font-bold leading-tight text-textPrimary">Premium Branding: Bulldog Breeder</h3>
                </div>
                
                <div class="flex flex-col mb-6 flex-grow">
                    <div class="flex gap-2 mb-4">
                        <span class="px-2 py-1 rounded-md bg-warning/10 text-warning text-[10px] font-bold uppercase tracking-wider">Speed</span>
                        <span class="px-2 py-1 rounded-md bg-blue-100 text-blue-700 text-[10px] font-bold uppercase tracking-wider">Brand</span>
                    </div>
                    <p class="text-[14px] text-textSecondary leading-[1.6] mb-4">
                        Built a premium mobile-first brand presence with stronger visual trust and reservation flow.
                    </p>
                    <div class="flex items-center gap-1.5 mt-auto pt-4 text-[14px] font-bold text-success">
                        <span class="w-1.5 h-1.5 rounded-full bg-success"></span> Stronger brand identity
                    </div>
                </div>
                
                <div class="flex justify-between items-center border-t border-borderLight pt-4 mt-auto">
                    <div class="flex items-center gap-1.5 text-[12px] text-textMuted font-medium">
                        <MapPin className="w-3.5 h-3.5" /> Niche Brand (AL)
                    </div>
                    <a href="#" class="text-[14px] font-[650] text-primary flex items-center gap-1.5 hover:text-primaryHover transition-colors">
                        Case Study <ArrowRight className="w-3.5 h-3.5" />
                    </a>
                </div>
            </div>
        </div>
    </div>

    <div class="w-full max-w-[400px] mx-auto mt-2 reveal-section">
        <a href="#work" class="w-full bg-surface border border-borderStrong text-textPrimary py-4 px-6 rounded-xl font-[650] text-[15px] hover:bg-surfaceMuted transition-colors block text-center">
            View All Projects
        </a>
    </div>
</section>