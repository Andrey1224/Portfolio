---
import { ImageOff, Image as ImageIcon, MapPin, ArrowRight, ChevronDown } from 'lucide-react';
---
<section class="w-full px-5 py-12 bg-bgMain border-t border-borderLight">
    <div class="max-w-2xl mx-auto w-full">
    <div class="text-center mb-8">
        <span class="text-[11px] font-[650] text-primary uppercase tracking-wide mb-2 block">The Proof</span>
        <h2 class="text-[28px] font-bold text-textPrimary">Case Studies</h2>
    </div>

    <!-- Главный кейс -->
    <div class="bg-surface border border-borderLight rounded-[24px] p-5 shadow-card mb-6">
        <div class="flex items-center gap-3 mb-4">
            <div class="w-6 h-6 rounded bg-primary text-white flex items-center justify-center text-[12px] font-bold">1</div>
            <h3 class="text-[18px] font-[650] leading-tight text-textPrimary">Veterinary Clinic Modernization</h3>
        </div>
        
        <div class="w-full h-[160px] flex gap-2 mb-4">
            <div class="w-1/2 bg-surfaceMuted rounded-lg border border-borderLight relative overflow-hidden flex items-center justify-center text-textMuted">
                <span class="absolute top-2 left-2 text-[10px] font-bold uppercase">Before</span>
                <ImageOff className="w-6 h-6 opacity-30" />
            </div>
            <div class="w-1/2 bg-surfaceWarm rounded-lg border border-borderLight relative overflow-hidden flex items-center justify-center text-success">
                <span class="absolute top-2 right-2 text-[10px] font-bold uppercase text-textPrimary">After</span>
                <ImageIcon className="w-6 h-6 opacity-50" />
            </div>
        </div>

        <div class="flex items-center gap-2 mb-3">
            <span class="text-[18px] font-bold text-success">100 / 100</span>
            <span class="text-[12px] text-textSecondary font-medium uppercase">Performance Score</span>
        </div>
        <p class="text-[14px] text-textSecondary leading-[1.5] mb-5">
            A full custom redesign and migration to a lightning-fast engine with Local SEO optimization.
        </p>
        <div class="flex justify-between items-center border-t border-borderLight pt-4">
            <div class="flex items-center gap-1.5 text-[12px] text-textMuted">
                <MapPin className="w-3.5 h-3.5" /> Local Healthcare (AL)
            </div>
            <a href="#" class="text-[14px] font-[650] text-textPrimary flex items-center gap-1">
                View Case Study <ArrowRight className="w-4 h-4" />
            </a>
        </div>
    </div>

    <!-- Вторичный кейс 1 -->
    <div class="bg-surface border border-borderLight rounded-[24px] p-5 shadow-subtle mb-6">
        <div class="flex items-start justify-between gap-4 mb-4">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-6 h-6 rounded bg-primarySoft text-primary flex items-center justify-center text-[12px] font-bold">2</div>
                    <h3 class="text-[16px] font-[650] leading-tight text-textPrimary">Senior Accessibility Redesign: Walk-In Baths</h3>
                </div>
            </div>
        </div>
        <div class="flex gap-4 mb-4">
            <div class="w-2/3">
                 <p class="text-[13px] text-textSecondary leading-[1.5] mb-3">
                    Re-engineered the UI with a focus on extreme accessibility, cleaned up technical debt.
                </p>
                <div class="flex items-center gap-2">
                    <span class="text-[16px] font-bold text-primary">2x</span>
                    <span class="text-[11px] text-textSecondary font-medium leading-tight">Increase in clarity<br>leading to inquiries.</span>
                </div>
            </div>
            <div class="w-1/3 bg-surfaceMuted rounded-lg border border-borderLight flex items-center justify-center text-textMuted">
                <ImageIcon className="w-6 h-6 opacity-30" />
            </div>
        </div>
        <div class="flex justify-between items-center border-t border-borderLight pt-4">
            <div class="flex items-center gap-1.5 text-[12px] text-textMuted">
                <MapPin className="w-3.5 h-3.5" /> High-Ticket Service (UK)
            </div>
            <a href="#" class="text-[13px] font-[650] text-textPrimary flex items-center gap-1">
                View Case Study <ArrowRight className="w-4 h-4" />
            </a>
        </div>
    </div>

    <!-- Вторичный кейс 2 -->
    <div class="bg-surface border border-borderLight rounded-[24px] p-5 shadow-subtle mb-6">
        <div class="flex items-start justify-between gap-4 mb-4">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-6 h-6 rounded bg-primarySoft text-primary flex items-center justify-center text-[12px] font-bold">3</div>
                    <h3 class="text-[16px] font-[650] leading-tight text-textPrimary">Premium Branding: Bulldog Breeder</h3>
                </div>
            </div>
        </div>
        <div class="flex gap-4 mb-4">
            <div class="w-2/3">
                 <p class="text-[13px] text-textSecondary leading-[1.5] mb-3">
                    Built a custom, visually rich platform focused on mobile speed and social proof.
                </p>
                <div class="text-[13px] font-bold text-success mb-1">Stronger brand identity</div>
            </div>
            <div class="w-1/3 bg-surfaceMuted rounded-lg border border-borderLight flex items-center justify-center text-textMuted">
                <ImageIcon className="w-6 h-6 opacity-30" />
            </div>
        </div>
        <div class="flex justify-between items-center border-t border-borderLight pt-4">
            <div class="flex items-center gap-1.5 text-[12px] text-textMuted">
                <MapPin className="w-3.5 h-3.5" /> Niche Private Brand (AL)
            </div>
            <a href="#" class="text-[13px] font-[650] text-textPrimary flex items-center gap-1">
                View Case Study <ArrowRight className="w-4 h-4" />
            </a>
        </div>
    </div>

    <button class="w-full bg-surface border border-borderStrong text-textPrimary py-4 rounded-xl font-[650] text-[15px] mt-2">
        View All Projects
    </button>
    
    <div class="w-full flex justify-center text-borderStrong mt-10">
        <ChevronDown className="w-6 h-6" />
    </div>
    </div>
</section>