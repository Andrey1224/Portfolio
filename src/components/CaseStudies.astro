---
import { ArrowRight, ChevronsLeftRight } from 'lucide-react';
---

<section id="work" class="w-full px-4 sm:px-8 py-16 lg:py-24 bg-surface brutal-border-b relative z-10">
	<div class="max-w-[1400px] mx-auto observe-block">
		<div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
			<div>
				<span class="text-[12px] font-mono font-bold text-primary uppercase tracking-widest block mb-4">[ 02. The Proof ]</span>
				<h2 class="text-fluid-h2 font-bold uppercase leading-none">
					<span class="reveal-overflow"><span class="reveal-text block">Proof, Not</span></span><br />
					<span class="reveal-overflow"><span class="reveal-text block">Promises.</span></span>
				</h2>
			</div>
		</div>

		<div class="stamp-item shadow-brutal delay-200 bg-bgMain brutal-border mb-10 flex flex-col lg:flex-row">
			<div class="p-5 sm:p-10 lg:p-12 lg:w-[40%] flex flex-col justify-between border-b-[3px] lg:border-b-0 lg:border-r-[3px] border-black">
				<div>
					<div class="font-mono text-[12px] font-bold uppercase tracking-widest bg-black text-white inline-block px-3 py-1.5 mb-6 brutal-border">Case Study 1</div>
					<h3 class="text-[26px] sm:text-[36px] font-bold uppercase leading-tight mb-5 sm:mb-6">Veterinary Clinic Modernization</h3>
					<p class="text-[16px] text-textSecondary font-[500] mb-8">
						Engineered a new architecture with a mobile-first approach, cleaned up SEO, and built a seamless lead capture flow.
					</p>
				</div>
				<div>
					<div class="flex items-center gap-4 mb-8 bg-success/20 p-4 brutal-border shadow-brutal-sm inline-flex hover:-translate-y-1 transition-transform">
						<span class="text-[32px] font-bold text-success leading-none">100/100</span>
						<span class="text-[12px] uppercase font-bold w-20 leading-tight">Performance Score</span>
					</div>
					<a href="#contact" class="w-full btn-brutal bg-surface text-black brutal-border px-6 py-4 font-bold uppercase text-[14px] tracking-wider shadow-brutal flex justify-center items-center gap-2">
						View Case Study <ArrowRight className="w-5 h-5" />
					</a>
				</div>
			</div>

			<div class="before-after-slider relative min-h-[240px] sm:min-h-[320px] lg:min-h-[500px] lg:w-[60%] select-none overflow-hidden bg-white">
				<div class="absolute inset-0 w-full h-full bg-[url('/images/AfterLee2.jpg')] bg-cover bg-top"></div>
				<div class="absolute top-4 right-4 lg:top-6 lg:right-6 bg-black text-white px-3 py-1 lg:px-4 lg:py-2 font-mono text-[10px] lg:text-[14px] font-bold uppercase z-10 brutal-border shadow-brutal-sm">After</div>

				<div class="before-image-wrapper absolute inset-0 w-1/2 h-full overflow-hidden z-10 border-r-[3px] border-black">
					<div class="before-inner absolute top-0 left-0 h-full bg-[url('/images/BeforeLee2.jpg')] bg-cover bg-top"></div>
					<div class="absolute top-4 left-4 lg:top-6 lg:left-6 bg-surface text-black brutal-border px-3 py-1 lg:px-4 lg:py-2 font-mono text-[10px] lg:text-[14px] font-bold uppercase z-20 shadow-brutal-sm">Before</div>
				</div>

				<div class="slider-line absolute top-0 bottom-0 left-1/2 w-[3px] bg-black pointer-events-none z-20 -ml-[1.5px]">
					<div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 slider-handle-brutal">
						<ChevronsLeftRight className="w-5 h-5 text-black" />
					</div>
				</div>
				<input type="range" min="0" max="100" value="50" autocomplete="off" aria-label="Compare before and after website" class="slider-input absolute inset-0 w-full h-full opacity-0 cursor-ew-resize z-30 m-0" />
			</div>
		</div>

		<div class="grid md:grid-cols-2 gap-6 lg:gap-10">
			<div class="stamp-item shadow-brutal delay-100 bg-bgMain brutal-border p-5 sm:p-6 lg:p-10 flex flex-col justify-between hover:bg-black hover:text-white transition-colors group">
				<div>
					<div class="font-mono text-[12px] font-bold text-textSecondary group-hover:text-gray-400 uppercase tracking-widest mb-4 transition-colors">[ Case Study 2 ]</div>
					<h3 class="text-[24px] font-bold uppercase leading-tight mb-4">Senior Accessibility Redesign</h3>
					<p class="text-[15px] text-textSecondary group-hover:text-gray-300 font-[500] mb-6 transition-colors">Re-engineered the UI with a focus on extreme accessibility and improved trust signals.</p>
				</div>
				<div>
					<div class="text-[16px] font-bold text-primary mb-6 border-l-4 border-primary pl-4 py-1 bg-surface group-hover:bg-gray-900 group-hover:text-white transition-colors">2x Increase in clarity & inquiries.</div>
					<a href="#contact" class="text-[14px] font-bold uppercase tracking-widest hover:text-primary flex items-center gap-2 group-hover:text-white">Read More <ArrowRight className="w-4 h-4" /></a>
				</div>
			</div>

			<div class="stamp-item shadow-brutal delay-200 bg-bgMain brutal-border p-5 sm:p-6 lg:p-10 flex flex-col justify-between hover:bg-black hover:text-white transition-colors group">
				<div>
					<div class="font-mono text-[12px] font-bold text-textSecondary group-hover:text-gray-400 uppercase tracking-widest mb-4 transition-colors">[ Case Study 3 ]</div>
					<h3 class="text-[24px] font-bold uppercase leading-tight mb-4">Premium Bulldog Breeder</h3>
					<p class="text-[15px] text-textSecondary group-hover:text-gray-300 font-[500] mb-6 transition-colors">Built a custom, visually rich platform focused on mobile speed, SEO foundation, and social proof.</p>
				</div>
				<div>
					<div class="text-[16px] font-bold text-success mb-6 border-l-4 border-success pl-4 py-1 bg-surface group-hover:bg-gray-900 group-hover:text-white transition-colors">Stronger brand identity established.</div>
					<a href="#contact" class="text-[14px] font-bold uppercase tracking-widest hover:text-primary flex items-center gap-2 group-hover:text-white">Read More <ArrowRight className="w-4 h-4" /></a>
				</div>
			</div>
		</div>
	</div>
</section>
