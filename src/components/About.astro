---
import { Check, ShieldCheck, ArrowDown } from 'lucide-react';
---

<!-- ========================================== -->
<!-- СЕКЦИЯ 5: ABOUT / TRUST (Sticky)           -->
<!-- ========================================== -->
<section id="about" class="sticky-section sticky top-0 w-full min-h-[100dvh] bg-bgMain border-t border-borderLight shadow-[0_-24px_80px_rgba(28,25,23,0.08)] rounded-t-[40px] flex flex-col justify-center py-24 z-50 relative overflow-hidden">
    <div class="max-w-[1240px] w-full mx-auto px-6">
        
        <!-- Заголовок секции -->
        <div class="text-center max-w-3xl mx-auto mb-16">
            <h2 class="text-[34px] sm:text-[44px] leading-[1.12] tracking-[-0.03em] font-bold text-textPrimary mb-6">
                A real technical partner, <br class="hidden sm:block"/>not a disappearing freelancer.
            </h2>
        </div>

        <div class="grid lg:grid-cols-12 gap-12 items-center">
            
            <!-- Левая колонка: Фото / Идентичность -->
            <div class="lg:col-span-5 w-full flex justify-center lg:justify-start">
                <div class="relative w-full max-w-[400px]">
                    <div class="aspect-[4/5] bg-surfaceMuted rounded-[32px] overflow-hidden border border-borderLight shadow-card flex items-center justify-center text-textMuted font-mono">
                        [Ваше фото]
                    </div>
                    <!-- Плашка с именем -->
                    <div class="absolute -bottom-6 -right-6 sm:-right-8 bg-surface border border-borderLight rounded-2xl p-5 shadow-elevated w-[260px]">
                        <h3 class="text-[20px] font-bold text-textPrimary mb-1">Andrii Nepodymka</h3>
                        <p class="text-[14px] text-textSecondary font-mono bg-surfaceMuted px-2 py-1 rounded inline-block mb-3">Web Developer</p>
                        <div class="flex items-center gap-2 text-[13px] text-textSecondary">
                            <div class="w-2 h-2 rounded-full bg-success"></div>
                            Based in Alabama
                        </div>
                    </div>
                </div>
            </div>

            <!-- Правая колонка: Доверие и Гарантии -->
            <div class="lg:col-span-7 flex flex-col items-start lg:pl-8 mt-12 lg:mt-0">
                
                <p class="text-[18px] leading-[1.65] text-textSecondary mb-10">
                    I’ve seen too many businesses get burned by developers who build a broken site and then vanish. My goal is simple: to build high-performance systems and be the person you can actually reach when you need help.
                </p>

                <!-- Чек-лист преимуществ -->
                <div class="grid sm:grid-cols-2 gap-x-8 gap-y-5 mb-12 w-full">
                    <div class="flex items-center gap-3">
                        <div class="w-6 h-6 rounded-full bg-success/10 text-success flex items-center justify-center flex-shrink-0">
                            <Check className="w-4 h-4 stroke-[2.5]" />
                        </div>
                        <span class="text-[16px] font-[550] text-textPrimary">Always responsive</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-6 h-6 rounded-full bg-success/10 text-success flex items-center justify-center flex-shrink-0">
                            <Check className="w-4 h-4 stroke-[2.5]" />
                        </div>
                        <span class="text-[16px] font-[550] text-textPrimary">Clean, fast code</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-6 h-6 rounded-full bg-success/10 text-success flex items-center justify-center flex-shrink-0">
                            <Check className="w-4 h-4 stroke-[2.5]" />
                        </div>
                        <span class="text-[16px] font-[550] text-textPrimary">No technical jargon</span>
                    </div>
                    <div class="flex items-center gap-3">
                        <div class="w-6 h-6 rounded-full bg-success/10 text-success flex items-center justify-center flex-shrink-0">
                            <Check className="w-4 h-4 stroke-[2.5]" />
                        </div>
                        <span class="text-[16px] font-[550] text-textPrimary">Direct communication</span>
                    </div>
                </div>

                <!-- Блок гарантии (No-Ghosting Promise) -->
                <div class="bg-surface border border-borderLight shadow-card rounded-[24px] p-6 sm:p-8 flex flex-col sm:flex-row gap-6 items-start">
                    <div class="w-14 h-14 bg-accentSoft text-accent rounded-full flex items-center justify-center flex-shrink-0">
                        <ShieldCheck className="w-7 h-7 stroke-[1.75]" />
                    </div>
                    <div>
                        <h4 class="text-[20px] font-[650] text-textPrimary mb-2">No-Ghosting Promise</h4>
                        <p class="text-[15px] leading-[1.6] text-textSecondary">
                            You’ll always know the project status, next steps, and how to reach me. I use clear scopes, timelines, and regular updates so you’re never left guessing.
                        </p>
                    </div>
                </div>

            </div>
        </div>

    </div>
    
    <!-- Индикатор следующей секции -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 text-borderStrong animate-bounce">
        <ArrowDown className="w-6 h-6" />
    </div>
</section>
