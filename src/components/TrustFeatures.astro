---
import { MapPin, Phone, ShieldCheck, Users } from 'lucide-react';
---

<div class="relative z-10 w-full h-[var(--hero-marquee-height)] bg-black text-white border-t-4 border-b-4 border-black marquee-container text-[4vw] font-bold uppercase cursor-crosshair overflow-hidden flex items-center">
	<div class="marquee-content gap-8 items-center whitespace-nowrap">
		<span>Fast Performance</span> <span class="text-primary">•</span>
		<span class="text-outline-white">Zero Ghosting</span> <span class="text-primary">•</span>
		<span>SEO Optimized</span> <span class="text-primary">•</span>
		<span class="text-outline-white">Mobile Perfect</span> <span class="text-primary">•</span>
		<span>Fast Performance</span> <span class="text-primary">•</span>
		<span class="text-outline-white">Zero Ghosting</span> <span class="text-primary">•</span>
		<span>SEO Optimized</span> <span class="text-primary">•</span>
		<span class="text-outline-white">Mobile Perfect</span> <span class="text-primary">•</span>
	</div>
</div>

<section class="relative z-10 w-full px-4 sm:px-8 py-12 lg:py-20 bg-surface brutal-border-b">
	<div class="max-w-[1400px] mx-auto flex flex-col lg:flex-row justify-between items-center gap-10 observe-block">
		<div class="text-center lg:text-left">
			<span class="text-[12px] font-mono font-bold uppercase tracking-widest text-textSecondary block mb-4">Alabama-Based Developer</span>
			<h2 class="text-fluid-trust font-bold uppercase leading-none">
				<span class="reveal-overflow"><span class="reveal-text block">Local. Reliable.</span></span><br />
				<span class="reveal-overflow"><span class="reveal-text block">Real Communication.</span></span>
			</h2>
		</div>

		<div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-8 w-full lg:w-auto">
			<div class="stamp-item shadow-brutal-sm delay-100 flex flex-col items-center lg:items-start text-center lg:text-left">
				<div class="w-12 h-12 lg:w-16 lg:h-16 brutal-border bg-bgMain flex items-center justify-center mb-4 text-primary">
					<MapPin className="w-6 h-6 lg:w-8 lg:h-8" />
				</div>
				<h3 class="text-[14px] lg:text-[16px] font-bold uppercase mb-2">Local Partner</h3>
			</div>
			<div class="stamp-item shadow-brutal-sm delay-200 flex flex-col items-center lg:items-start text-center lg:text-left">
				<div class="w-12 h-12 lg:w-16 lg:h-16 brutal-border bg-bgMain flex items-center justify-center mb-4 text-primary">
					<Phone className="w-6 h-6 lg:w-8 lg:h-8" />
				</div>
				<h3 class="text-[14px] lg:text-[16px] font-bold uppercase mb-2">Direct Access</h3>
			</div>
			<div class="stamp-item shadow-brutal-sm delay-300 flex flex-col items-center lg:items-start text-center lg:text-left">
				<div class="w-12 h-12 lg:w-16 lg:h-16 brutal-border bg-bgMain flex items-center justify-center mb-4 text-primary">
					<Users className="w-6 h-6 lg:w-8 lg:h-8" />
				</div>
				<h3 class="text-[14px] lg:text-[16px] font-bold uppercase mb-2">No Ghosting</h3>
			</div>
			<div class="stamp-item shadow-brutal-sm delay-400 flex flex-col items-center lg:items-start text-center lg:text-left">
				<div class="w-12 h-12 lg:w-16 lg:h-16 brutal-border bg-bgMain flex items-center justify-center mb-4 text-primary">
					<ShieldCheck className="w-6 h-6 lg:w-8 lg:h-8" />
				</div>
				<h3 class="text-[14px] lg:text-[16px] font-bold uppercase mb-2">Long-term</h3>
			</div>
		</div>
	</div>
</section>
