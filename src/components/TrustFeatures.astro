---
import { MapPin, Phone, ShieldCheck, Users } from 'lucide-react';
---

<div class="relative z-10 w-full h-[var(--hero-marquee-height)] bg-black text-white border-t-4 border-b-4 border-black marquee-container text-[4vw] font-bold uppercase cursor-crosshair overflow-hidden flex items-center">
	<div class="marquee-content gap-8 items-center whitespace-nowrap">
		<span>Fast Performance</span> <span class="text-primary">•</span>
		<span class="text-outline-white">Zero Ghosting</span> <span class="text-primary">•</span>
		<span>SEO Optimized</span> <span class="text-primary">•</span>
		<span class="text-outline-white">Mobile Perfect</span> <span class="text-primary">•</span>
		<span>Fast Performance</span> <span class="text-primary">•</span>
		<span class="text-outline-white">Zero Ghosting</span> <span class="text-primary">•</span>
		<span>SEO Optimized</span> <span class="text-primary">•</span>
		<span class="text-outline-white">Mobile Perfect</span> <span class="text-primary">•</span>
	</div>
</div>

<section class="relative z-10 w-full px-4 sm:px-8 py-12 lg:py-20 bg-surface brutal-border-b">
	<div class="max-w-[1400px] mx-auto flex flex-col lg:flex-row justify-between items-center gap-10 observe-block">
		<div class="text-center lg:text-left">
			<span class="text-[12px] font-mono font-bold uppercase tracking-widest text-textSecondary block mb-4">Alabama-Based Developer</span>
			<h2 class="text-fluid-trust font-bold uppercase leading-none">
				<span class="reveal-overflow"><span class="reveal-text block">Local. Reliable.</span></span><br />
				<span class="reveal-overflow"><span class="reveal-text block"><span class="bg-primary text-white px-3 pb-1 -ml-3 brutal-border inline-block transform -rotate-2 shadow-[4px_4px_0_0_#000]">REAL</span> COMMUNICATION.</span></span>
			</h2>
		</div>

		<div class="grid grid-cols-2 md:grid-cols-4 gap-6 md:gap-8 w-full lg:w-auto mt-10 lg:mt-0">
			<div class="stamp-item transform rotate-1 hover:-rotate-1 transition-transform bg-white brutal-border border-4 p-4 lg:p-6 shadow-[8px_8px_0_0_#000] flex flex-col items-center lg:items-start text-center lg:text-left">
				<div class="w-14 h-14 lg:w-16 lg:h-16 bg-primary text-white flex items-center justify-center mb-4 brutal-border border-[3px]">
					<MapPin className="w-8 h-8" strokeWidth={2.5} />
				</div>
				<h3 class="text-[15px] lg:text-[18px] font-black uppercase tracking-tight leading-tight">Local<br>Partner</h3>
			</div>
			
			<div class="stamp-item transform -rotate-2 hover:rotate-1 transition-transform bg-warning brutal-border border-4 p-4 lg:p-6 shadow-[8px_8px_0_0_#000] flex flex-col items-center lg:items-start text-center lg:text-left mt-2 lg:mt-0">
				<div class="w-14 h-14 lg:w-16 lg:h-16 bg-black text-warning flex items-center justify-center mb-4 brutal-border border-[3px] border-black">
					<Phone className="w-8 h-8" strokeWidth={2.5} />
				</div>
				<h3 class="text-[15px] lg:text-[18px] font-black uppercase tracking-tight leading-tight">Direct<br>Access</h3>
			</div>
			
			<div class="stamp-item transform rotate-2 hover:-rotate-2 transition-transform bg-white brutal-border border-4 p-4 lg:p-6 shadow-[8px_8px_0_0_#000] flex flex-col items-center lg:items-start text-center lg:text-left">
				<div class="w-14 h-14 lg:w-16 lg:h-16 bg-success text-white flex items-center justify-center mb-4 brutal-border border-[3px]">
					<Users className="w-8 h-8" strokeWidth={2.5} />
				</div>
				<h3 class="text-[15px] lg:text-[18px] font-black uppercase tracking-tight leading-tight">No<br>Ghosting</h3>
			</div>
			
			<div class="stamp-item transform -rotate-1 hover:rotate-2 transition-transform bg-white brutal-border border-4 p-4 lg:p-6 shadow-[8px_8px_0_0_#000] flex flex-col items-center lg:items-start text-center lg:text-left mt-2 lg:mt-0">
				<div class="w-14 h-14 lg:w-16 lg:h-16 bg-black text-white flex items-center justify-center mb-4 brutal-border border-[3px] border-black">
					<ShieldCheck className="w-8 h-8" strokeWidth={2.5} />
				</div>
				<h3 class="text-[15px] lg:text-[18px] font-black uppercase tracking-tight leading-tight">Long<br>Term</h3>
			</div>
		</div>
	</div>
</section>
