---
import { MapPin, Phone, Users, ChevronDown } from 'lucide-react';
---
<section class="w-full px-5 py-12 bg-surfaceMuted flex flex-col items-center text-center border-t border-borderLight">
    <span class="text-[11px] font-[650] text-textMuted uppercase tracking-wide mb-2">Alabama-Based Developer</span>
    <h2 class="text-[26px] leading-[1.15] font-bold text-textPrimary mb-10">Local. Reliable. Real communication.</h2>
    
    <div class="grid grid-cols-3 gap-2 w-full mb-10">
        <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-borderLight flex items-center justify-center mb-3 text-textPrimary">
                <MapPin className="w-5 h-5" />
            </div>
            <h3 class="text-[12px] font-bold text-textPrimary mb-1">Local Partner</h3>
            <p class="text-[11px] leading-[1.4] text-textSecondary">Based in Alabama and working state-wide.</p>
        </div>
        <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-borderLight flex items-center justify-center mb-3 text-textPrimary">
                <Phone className="w-5 h-5" />
            </div>
            <h3 class="text-[12px] font-bold text-textPrimary mb-1">Direct Comm.</h3>
            <p class="text-[11px] leading-[1.4] text-textSecondary">You work with me directly. I pick up.</p>
        </div>
        <div class="flex flex-col items-center">
            <div class="w-12 h-12 rounded-full bg-borderLight flex items-center justify-center mb-3 text-textPrimary">
                <Users className="w-5 h-5" />
            </div>
            <h3 class="text-[12px] font-bold text-textPrimary mb-1">No Ghosting</h3>
            <p class="text-[11px] leading-[1.4] text-textSecondary">Clear timelines and ongoing support.</p>
        </div>
    </div>

    <div class="text-[12px] text-textSecondary font-medium">
        Trusted by businesses in<br>
        <span class="text-textPrimary font-bold">Birmingham • Huntsville • Mobile • Montgomery</span>
    </div>
    
    <div class="w-full flex justify-center text-borderStrong mt-8">
        <ChevronDown className="w-6 h-6" />
    </div>
</section>