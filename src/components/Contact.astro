---
import { ShieldCheck, Gift, Clock } from 'lucide-react';
---
<section id="cta" class="w-full px-5 py-12 bg-surfaceMuted border-t border-borderLight rounded-t-[32px] mt-[-20px] relative z-10 flex flex-col items-center text-center">
    <span class="text-[11px] font-[650] text-primary uppercase tracking-wide mb-3 block">Ready to Grow?</span>
    <h2 class="text-[28px] font-bold text-textPrimary leading-[1.15] mb-4">Let's Fix What's Holding Your Website Back</h2>
    <p class="text-[15px] text-textSecondary mb-8">Get a clear plan, a fast website, and more leads for your business.</p>

    <div class="flex flex-col gap-3 w-full mb-8">
        <button class="w-full bg-dark text-white py-4 rounded-xl shadow-btn font-[650] text-[15px]">
            Book a Free Strategy Call
        </button>
        <button class="w-full bg-surface text-textPrimary border border-borderStrong py-4 rounded-xl font-[650] text-[15px]">
            Get My Free Technical Audit
        </button>
    </div>

    <div class="flex items-center justify-center gap-5 text-[12px] font-[550] text-textSecondary">
        <div class="flex items-center gap-1.5">
            <ShieldCheck className="w-4 h-4 text-textPrimary" /> No pressure
        </div>
        <div class="flex items-center gap-1.5">
            <Gift className="w-4 h-4 text-textPrimary" /> 100% Free
        </div>
        <div class="flex items-center gap-1.5">
            <Clock className="w-4 h-4 text-textPrimary" /> 20-30 min
        </div>
    </div>
</section>