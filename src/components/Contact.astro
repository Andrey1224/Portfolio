---
import { ArrowUpRight } from 'lucide-react';
---

<section id="contact" class="w-full px-4 sm:px-8 py-24 lg:py-32 bg-primary text-white brutal-border-b flex flex-col items-center text-center relative overflow-hidden z-10">
	<div class="absolute -top-16 -right-16 lg:-top-32 lg:-right-32 w-48 h-48 lg:w-96 lg:h-96 border-[12px] lg:border-[24px] border-black rounded-full opacity-20 pointer-events-none"></div>
	<div class="absolute -bottom-16 -left-16 lg:-bottom-32 lg:-left-32 w-48 h-48 lg:w-96 lg:h-96 border-[12px] lg:border-[24px] border-black rounded-full opacity-20 pointer-events-none"></div>

	<div class="max-w-[1000px] mx-auto z-10 flex flex-col items-center observe-block">
		<span class="stamp-item shadow-brutal-sm delay-100 text-[12px] md:text-[14px] font-mono font-bold text-black uppercase tracking-widest bg-white brutal-border px-4 py-2 mb-10 z-10">
			Ready to Scale?
		</span>

		<h2 class="text-fluid-hero font-bold uppercase leading-none mb-8 z-10 text-outline-white text-transparent drop-shadow-[6px_6px_0_#000]">
			<span class="reveal-overflow"><span class="reveal-text block delay-100">Let's Fix</span></span><br />
			<span class="reveal-overflow"><span class="reveal-text block delay-200">Your Site.</span></span>
		</h2>

		<p class="stamp-item delay-300 text-[18px] md:text-[22px] font-[500] mb-12 max-w-2xl z-10">
			Get a clear plan, a faster website, and a technical partner who keeps things moving.
		</p>

		<div class="flex flex-col sm:flex-row gap-6 w-full justify-center z-10 mb-10">
			<a href="mailto:hello@andrii.dev" class="stamp-item shadow-brutal delay-400 btn-brutal w-full sm:w-auto bg-black text-white border-[3px] border-black px-8 py-4 font-bold uppercase tracking-widest text-[16px] flex justify-center items-center gap-3">
				Free Strategy Call <ArrowUpRight className="w-6 h-6" />
			</a>
			<a href="mailto:hello@andrii.dev?subject=Technical Audit Request" class="stamp-item shadow-brutal delay-400 btn-brutal w-full sm:w-auto bg-white text-black brutal-border px-8 py-4 font-bold uppercase tracking-widest text-[16px]">
				Get Technical Audit
			</a>
		</div>
	</div>
</section>
