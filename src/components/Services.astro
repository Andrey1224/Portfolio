---
import { Search, Settings, Bot, Wrench, ChevronRight, ChevronDown, Sparkles } from 'lucide-react';
---
<section id="services" class="w-full px-5 py-12 lg:py-20 bg-surfaceWarm border-t border-borderLight flex flex-col items-center">
    <div class="max-w-7xl mx-auto w-full">
    <div class="text-center mb-10 lg:mb-16 reveal-section">
        <span class="text-[11px] font-[650] text-primary uppercase tracking-wide mb-2 lg:mb-4 block">How I can help</span>
        <h2 class="text-[28px] lg:text-[40px] font-bold text-textPrimary">Services</h2>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 lg:gap-6 mb-10 lg:mb-12">
        <!-- Service 1 -->
        <div class="bg-surface border border-borderLight rounded-[24px] p-6 lg:p-8 flex flex-col items-start shadow-subtle hover-lift hover:border-primary/20 reveal-card group">
            <div class="w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-primary/10 flex items-center justify-center text-primary mb-5 group-hover:scale-110 transition-transform">
                <Search className="w-6 h-6 lg:w-7 lg:h-7" />
            </div>
            <h3 class="text-[16px] lg:text-[20px] font-[650] text-textPrimary mb-2">1. The Diagnostic Audit</h3>
            <p class="text-[14px] lg:text-[15px] font-medium text-textPrimary mb-2">Find what's slowing your website down.</p>
            <p class="text-[13px] lg:text-[15px] text-textSecondary leading-[1.6] mb-6 flex-grow">Technical review, SEO gap scan, speed check, and prioritized action plan.</p>
            <div class="w-full flex justify-between items-center border-t border-borderLight pt-4 mt-auto">
                <span class="text-[13px] lg:text-[14px] font-bold text-textPrimary">Starting at $500–$1,500</span>
                <ChevronRight className="w-5 h-5 text-textMuted group-hover:text-primary transition-colors group-hover:translate-x-1" />
            </div>
        </div>
        
        <!-- Service 2 (Highlighted) -->
        <div class="bg-gradient-to-br from-[#EEF2FF] to-white border-2 border-primary/20 rounded-[24px] p-6 lg:p-8 flex flex-col items-start shadow-card hover-lift hover:border-primary/40 reveal-card reveal-delay-1 group relative overflow-hidden">
            <div class="absolute top-0 right-0 bg-primary text-white text-[10px] font-bold uppercase tracking-wider px-3 py-1.5 rounded-bl-xl flex items-center gap-1"><Sparkles className="w-3 h-3"/> Most Recommended</div>
            <div class="w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-primary/20 flex items-center justify-center text-primary mb-5 group-hover:scale-110 transition-transform">
                <Settings className="w-6 h-6 lg:w-7 lg:h-7" />
            </div>
            <h3 class="text-[16px] lg:text-[20px] font-[650] text-primary mb-2">2. The Modernization Engine</h3>
            <p class="text-[14px] lg:text-[15px] font-medium text-textPrimary mb-2">Replace your outdated website with a faster, cleaner system.</p>
            <p class="text-[13px] lg:text-[15px] text-textSecondary leading-[1.6] mb-6 flex-grow">Custom redesign, mobile-first build, SEO setup, lead forms, and launch support.</p>
            <div class="w-full flex justify-between items-center border-t border-primary/10 pt-4 mt-auto">
                <span class="text-[13px] lg:text-[14px] font-bold text-primary">Starting at $5,000+</span>
                <ChevronRight className="w-5 h-5 text-primary group-hover:translate-x-1 transition-transform" />
            </div>
        </div>
        
        <!-- Service 3 -->
        <div class="bg-surface border border-borderLight rounded-[24px] p-6 lg:p-8 flex flex-col items-start shadow-subtle hover-lift hover:border-accent/30 reveal-card group">
            <div class="w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-accent/10 flex items-center justify-center text-accent mb-5 group-hover:scale-110 transition-transform">
                <Bot className="w-6 h-6 lg:w-7 lg:h-7" />
            </div>
            <h3 class="text-[16px] lg:text-[20px] font-[650] text-textPrimary mb-2">3. The AI Edge</h3>
            <p class="text-[14px] lg:text-[15px] font-medium text-textPrimary mb-2">Use automation to respond faster and save time.</p>
            <p class="text-[13px] lg:text-[15px] text-textSecondary leading-[1.6] mb-6 flex-grow">Lead routing, AI chat/support tools, Make/Zapier workflows, and intake automation.</p>
            <div class="w-full flex justify-between items-center border-t border-borderLight pt-4 mt-auto">
                <span class="text-[13px] lg:text-[14px] font-bold text-textPrimary">Starting at $3,000+</span>
                <ChevronRight className="w-5 h-5 text-textMuted group-hover:text-accent transition-colors group-hover:translate-x-1" />
            </div>
        </div>
        
        <!-- Service 4 -->
        <div class="bg-surface border border-borderLight rounded-[24px] p-6 lg:p-8 flex flex-col items-start shadow-subtle hover-lift hover:border-warning/30 reveal-card reveal-delay-1 group">
            <div class="w-12 h-12 lg:w-14 lg:h-14 rounded-full bg-warning/10 flex items-center justify-center text-warning mb-5 group-hover:scale-110 transition-transform">
                <Wrench className="w-6 h-6 lg:w-7 lg:h-7" />
            </div>
            <h3 class="text-[16px] lg:text-[20px] font-[650] text-textPrimary mb-2">4. Technical Rescue</h3>
            <p class="text-[14px] lg:text-[15px] font-medium text-textPrimary mb-2">Fix what's broken without rebuilding everything.</p>
            <p class="text-[13px] lg:text-[15px] text-textSecondary leading-[1.6] mb-6 flex-grow">Bug fixes, SEO errors, speed optimization, broken forms, and emergency cleanup.</p>
            <div class="w-full flex justify-between items-center border-t border-borderLight pt-4 mt-auto">
                <span class="text-[13px] lg:text-[14px] font-bold text-textPrimary">Starting at $750+</span>
                <ChevronRight className="w-5 h-5 text-textMuted group-hover:text-warning transition-colors group-hover:translate-x-1" />
            </div>
        </div>
    </div>

    <div class="w-full max-w-[400px] mx-auto reveal-section">
        <a href="#contact" class="w-full bg-primary text-white py-4 px-6 rounded-xl shadow-btn font-[650] text-[15px] hover:bg-primaryHover transition-colors block text-center">
            See Service Packages & Pricing
        </a>
    </div>
    
    <div class="w-full flex justify-center text-borderStrong mt-10 lg:hidden">
        <ChevronDown className="w-6 h-6" />
    </div>
    </div>
</section>