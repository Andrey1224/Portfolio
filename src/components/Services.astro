---
import { Bot, Check, Search, Settings, Wrench } from 'lucide-react';
---

<section id="services" class="w-full px-4 sm:px-8 py-16 lg:py-24 bg-black text-white brutal-border-b relative z-10">
	<div class="max-w-[1400px] mx-auto observe-block">
		<span class="text-[12px] font-mono font-bold text-primary uppercase tracking-widest block mb-4">[ 03. Solutions ]</span>
		<h2 class="text-fluid-h2 font-bold uppercase mb-12 lg:mb-16 leading-none text-outline-white text-transparent">
			<span class="reveal-overflow"><span class="reveal-text block">How I Build.</span></span>
		</h2>

		<div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8 mb-12">
			<div class="stamp-item shadow-brutal-white-sm delay-100 bg-surface text-black brutal-border p-8 relative flex flex-col hover:-translate-y-2 transition-transform duration-300">
				<div class="absolute -top-3 -right-3 bg-bgMain brutal-border p-2 font-mono text-[14px] font-bold shadow-brutal-sm">01</div>
				<Search className="w-10 h-10 mb-6 text-primary" />
				<h3 class="text-[22px] font-bold uppercase mb-3 border-b-[3px] border-black pb-3">Diagnostic Audit</h3>
				<p class="text-[15px] font-[500] text-textSecondary mb-8 flex-grow">Deep-dive technical review to find what's slowing your website down and hurting SEO.</p>
				<div class="font-mono text-[14px] font-bold bg-bgMain border-[2px] border-black inline-block px-3 py-1.5 shadow-brutal-hover self-start">Starts at $500</div>
			</div>

			<div class="stamp-item shadow-brutal-white delay-200 bg-primary text-white border-4 border-white p-8 relative flex flex-col hover:-translate-y-2 transition-transform duration-300">
				<div class="absolute -top-3 -right-3 bg-black text-white border-[3px] border-white p-2 font-mono text-[14px] font-bold shadow-[3px_3px_0px_#FFFFFF]">02</div>
				<Settings className="w-12 h-12 mb-6" />
				<h3 class="text-[24px] font-bold uppercase mb-3 border-b-2 border-white/40 pb-3">Modernization Engine</h3>
				<p class="text-[15px] font-[500] text-white/90 mb-6 flex-grow">Full migration to a custom, lightning-fast system built to scale. Zero maintenance.</p>
				<ul class="text-[12px] font-bold uppercase tracking-wider space-y-3 mb-8">
					<li class="flex items-center gap-2"><Check className="w-5 h-5 text-black flex-shrink-0" /> Custom Redesign</li>
					<li class="flex items-center gap-2"><Check className="w-5 h-5 text-black flex-shrink-0" /> Mobile-First Architecture</li>
				</ul>
				<div class="font-mono text-[14px] font-bold bg-black text-white inline-block px-3 py-1.5 border-2 border-white shadow-[2px_2px_0_#FFF] self-start">Starts at $5,000+</div>
			</div>

			<div class="stamp-item shadow-brutal-white-sm delay-300 bg-surface text-black brutal-border p-8 relative flex flex-col hover:-translate-y-2 transition-transform duration-300">
				<div class="absolute -top-3 -right-3 bg-bgMain brutal-border p-2 font-mono text-[14px] font-bold shadow-brutal-sm">03</div>
				<Wrench className="w-10 h-10 mb-6 text-primary" />
				<h3 class="text-[22px] font-bold uppercase mb-3 border-b-[3px] border-black pb-3">Technical Rescue</h3>
				<p class="text-[15px] font-[500] text-textSecondary mb-8 flex-grow">Fast fixes for broken forms, slow pages, plugin issues, SEO errors, and neglected websites.</p>
				<div class="font-mono text-[14px] font-bold bg-bgMain border-[2px] border-black inline-block px-3 py-1.5 shadow-brutal-hover self-start">Starts at $750</div>
			</div>

			<div class="stamp-item shadow-brutal-white-sm delay-400 bg-surface text-black brutal-border p-8 relative flex flex-col hover:-translate-y-2 transition-transform duration-300">
				<div class="absolute -top-3 -right-3 bg-bgMain brutal-border p-2 font-mono text-[14px] font-bold shadow-brutal-sm">04</div>
				<Bot className="w-10 h-10 mb-6 text-primary" />
				<h3 class="text-[22px] font-bold uppercase mb-3 border-b-[3px] border-black pb-3">AI Edge</h3>
				<p class="text-[15px] font-[500] text-textSecondary mb-8 flex-grow">Implement smart automation and chat tools to capture leads 24/7 and save time.</p>
				<div class="font-mono text-[14px] font-bold bg-bgMain border-[2px] border-black inline-block px-3 py-1.5 shadow-brutal-hover self-start">Starts at $3,000+</div>
			</div>
		</div>
	</div>
</section>
