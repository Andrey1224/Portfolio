---
import { Search, Settings, Bot, Wrench, ChevronRight, ChevronDown } from 'lucide-react';
---
<section class="w-full px-5 py-12 bg-surfaceWarm border-t border-borderLight">
    <div class="text-center mb-8">
        <span class="text-[11px] font-[650] text-primary uppercase tracking-wide mb-2 block">How I can help</span>
        <h2 class="text-[28px] font-bold text-textPrimary">Services</h2>
    </div>

    <div class="flex flex-col gap-3 mb-8">
        <!-- Услуга 1 -->
        <div class="bg-surface border border-borderLight rounded-2xl p-4 flex gap-4 items-center shadow-subtle relative">
            <div class="w-12 h-12 rounded-full bg-surfaceMuted flex items-center justify-center text-primary flex-shrink-0">
                <Search className="w-6 h-6" />
            </div>
            <div class="flex-grow pr-6">
                <h3 class="text-[15px] font-[650] text-textPrimary mb-1">1. The Diagnostic Audit</h3>
                <p class="text-[13px] text-textSecondary leading-[1.4]">Deep-dive into your site's code, SEO, and content gaps.</p>
            </div>
            <ChevronRight className="w-5 h-5 text-textMuted absolute right-4" />
        </div>
        <!-- Услуга 2 -->
        <div class="bg-surface border border-borderLight rounded-2xl p-4 flex gap-4 items-center shadow-subtle relative">
            <div class="w-12 h-12 rounded-full bg-surfaceMuted flex items-center justify-center text-textPrimary flex-shrink-0">
                <Settings className="w-6 h-6" />
            </div>
            <div class="flex-grow pr-6">
                <h3 class="text-[15px] font-[650] text-textPrimary mb-1">2. The Modernization Engine</h3>
                <p class="text-[13px] text-textSecondary leading-[1.4]">Full redesign. Moving you to a custom, fast system.</p>
            </div>
            <ChevronRight className="w-5 h-5 text-textMuted absolute right-4" />
        </div>
        <!-- Услуга 3 -->
        <div class="bg-surface border border-borderLight rounded-2xl p-4 flex gap-4 items-center shadow-subtle relative">
            <div class="w-12 h-12 rounded-full bg-surfaceMuted flex items-center justify-center text-accent flex-shrink-0">
                <Bot className="w-6 h-6" />
            </div>
            <div class="flex-grow pr-6">
                <h3 class="text-[15px] font-[650] text-textPrimary mb-1">3. The AI Edge</h3>
                <p class="text-[13px] text-textSecondary leading-[1.4]">Custom chatbots and automation to capture leads 24/7.</p>
            </div>
            <ChevronRight className="w-5 h-5 text-textMuted absolute right-4" />
        </div>
        <!-- Услуга 4 -->
        <div class="bg-surface border border-borderLight rounded-2xl p-4 flex gap-4 items-center shadow-subtle relative">
            <div class="w-12 h-12 rounded-full bg-surfaceMuted flex items-center justify-center text-warning flex-shrink-0">
                <Wrench className="w-6 h-6" />
            </div>
            <div class="flex-grow pr-6">
                <h3 class="text-[15px] font-[650] text-textPrimary mb-1">4. Technical Rescue</h3>
                <p class="text-[13px] text-textSecondary leading-[1.4]">I hunt down bugs, fix SEO errors, and optimize speed.</p>
            </div>
            <ChevronRight className="w-5 h-5 text-textMuted absolute right-4" />
        </div>
    </div>

    <button class="w-full bg-dark text-white py-4 rounded-xl font-[650] text-[15px]">
        See Service Packages & Pricing
    </button>
    
    <div class="w-full flex justify-center text-borderStrong mt-10">
        <ChevronDown className="w-6 h-6" />
    </div>
</section>