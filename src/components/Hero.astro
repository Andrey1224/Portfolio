---
import { ShieldCheck, ChevronDown } from 'lucide-react';
---
<section class="w-full px-5 py-10 bg-bgMain flex flex-col items-start relative">
    <div class="max-w-2xl mx-auto w-full">
    <!-- Бейдж -->
    <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface border border-borderLight text-textSecondary text-[12px] font-[550] mb-6 shadow-subtle">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
        </span>
        Available for new projects in Alabama
    </div>

    <!-- Главный заголовок -->
    <h1 class="text-[36px] leading-[1.08] tracking-[-0.035em] font-bold text-textPrimary mb-4">
        I Build & Repair High-Performance Websites for Alabama Small Business.
    </h1>

    <!-- Подзаголовок -->
    <p class="text-[16px] leading-[1.6] text-textSecondary mb-8">
        Stop losing customers to a slow, broken website. I replace outdated systems with custom, fast websites and automation that generate leads 24/7.
    </p>

    <!-- Кнопки CTA -->
    <div class="flex flex-col gap-3 w-full mb-8">
        <button class="w-full bg-dark text-white px-6 py-4 rounded-xl shadow-btn font-[650] text-[15px] flex items-center justify-center">
            Get My Free Technical Audit
        </button>
        <button class="w-full bg-surface text-textPrimary border border-borderStrong px-6 py-4 rounded-xl font-[650] text-[15px] flex items-center justify-center">
            View My Work
        </button>
    </div>

    <!-- Строка доверия -->
    <div class="flex items-center gap-3 text-[14px] text-textSecondary mb-12">
        <ShieldCheck className="w-5 h-5 flex-shrink-0 text-textPrimary" />
        <span class="font-medium">I don't just write code.<br>I build stability for your business.</span>
    </div>

    <!-- Мокап визуал -->
    <div class="w-full bg-surfaceMuted rounded-2xl border border-borderLight h-[220px] relative overflow-hidden shadow-subtle mb-6">
        <div class="absolute top-4 left-4 right-4 h-full bg-surface rounded-t-lg border border-borderLight shadow-sm">
            <div class="flex gap-1.5 p-2 border-b border-borderLight bg-surfaceMuted">
                <div class="w-2 h-2 rounded-full bg-borderStrong"></div>
                <div class="w-2 h-2 rounded-full bg-borderStrong"></div>
                <div class="w-2 h-2 rounded-full bg-borderStrong"></div>
            </div>
            <div class="p-4">
                <div class="w-1/2 h-4 bg-textPrimary rounded mb-2"></div>
                <div class="w-3/4 h-2 bg-textMuted rounded mb-4"></div>
                <div class="w-20 h-6 bg-borderStrong rounded-sm"></div>
            </div>
        </div>
        <div class="absolute -bottom-2 right-4 w-[100px] h-[160px] bg-surface rounded-[16px] border-[4px] border-dark shadow-mockup">
            <div class="p-2 pt-6">
                <div class="w-full h-12 bg-surfaceMuted rounded mb-2"></div>
                <div class="w-full h-2 bg-textPrimary rounded mb-1"></div>
                <div class="w-2/3 h-2 bg-textPrimary rounded"></div>
            </div>
        </div>
    </div>
    
    <div class="w-full flex justify-center text-borderStrong pt-4">
        <ChevronDown className="w-6 h-6" />
    </div>
    </div>
</section>