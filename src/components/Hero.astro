---
import { ShieldCheck, ChevronDown } from 'lucide-react';
---
<section class="w-full px-5 py-12 pt-20 lg:py-24 lg:pt-32 bg-bgMain flex flex-col items-start relative overflow-hidden">
    <!-- Warm technical dot pattern -->
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: radial-gradient(#1C1917 1.5px, transparent 1.5px); background-size: 24px 24px;"></div>
    <!-- Optional background accent for desktop to make it feel premium -->
    <div class="hidden lg:block absolute top-0 right-0 w-[600px] h-[600px] bg-primary/5 rounded-full blur-[100px] -z-10 translate-x-1/2 -translate-y-1/2"></div>
    
    <div class="max-w-7xl mx-auto w-full grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center z-10 reveal-section">
        <!-- Left Column: Content -->
        <div class="flex flex-col items-start">
            <!-- Badge -->
            <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-surface border border-borderLight text-textSecondary text-[12px] font-[550] mb-6 shadow-subtle">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-success"></span>
                </span>
                Available for new projects in Alabama
            </div>

            <!-- Headline -->
            <h1 class="text-[36px] lg:text-[52px] leading-[1.08] tracking-[-0.035em] font-bold text-textPrimary mb-4 lg:mb-6">
                I Build & Repair High-Performance Websites for Alabama Small Businesses.
            </h1>

            <!-- Subheadline -->
            <p class="text-[16px] lg:text-[18px] leading-[1.6] text-textSecondary mb-8 max-w-[500px]">
                Stop losing customers to a slow, broken website. I replace outdated systems with custom, fast websites and automation that generate leads 24/7.
            </p>

            <!-- CTAs -->
            <div class="flex flex-col sm:flex-row gap-3 w-full sm:w-auto mb-8">
                <a href="#contact" class="w-full sm:w-auto bg-primary text-white px-6 py-4 rounded-xl shadow-btn font-[650] text-[15px] flex items-center justify-center hover:bg-primaryHover transition-colors">
                    Get My Free Technical Audit
                </a>
                <a href="#work" class="w-full sm:w-auto bg-surface text-textPrimary border border-borderStrong px-6 py-4 rounded-xl font-[650] text-[15px] flex items-center justify-center hover:bg-surfaceMuted transition-colors">
                    View My Work
                </a>
            </div>

            <!-- Trust line -->
            <div class="flex items-center gap-3 text-[14px] text-textSecondary mb-12 lg:mb-0">
                <ShieldCheck className="w-5 h-5 flex-shrink-0 text-textPrimary" />
                <span class="font-medium">I don't just write code.<br class="lg:hidden">I build stability for your business.</span>
            </div>
        </div>

        <!-- Right Column: Visuals -->
        <div class="relative w-full h-[300px] lg:h-[500px] flex items-center justify-center">
            <!-- Desktop Mockup Frame -->
            <div class="absolute right-0 lg:right-10 top-0 lg:top-10 w-[90%] lg:w-[110%] h-[240px] lg:h-[380px] bg-surface rounded-2xl border border-borderLight shadow-lg overflow-hidden z-10 group hover:-translate-y-1 transition-transform duration-500">
                <!-- Browser Bar -->
                <div class="flex items-center gap-2 px-4 py-3 bg-surfaceMuted border-b border-borderLight">
                    <div class="w-2.5 h-2.5 rounded-full bg-borderStrong/50"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-borderStrong/50"></div>
                    <div class="w-2.5 h-2.5 rounded-full bg-borderStrong/50"></div>
                    <div class="ml-4 flex-1 h-4 bg-surface rounded-md border border-borderLight flex items-center px-2">
                        <div class="w-20 h-1.5 bg-borderStrong/20 rounded-full"></div>
                    </div>
                </div>
                <!-- Browser Content Placeholder -->
                <div class="p-6 lg:p-10 flex flex-col gap-4 relative h-full bg-gradient-to-br from-surface to-surfaceMuted">
                    <div class="absolute inset-0 bg-[url('/favicon.svg')] opacity-[0.03] bg-center bg-no-repeat bg-[length:200px_200px]"></div>
                    <div class="w-1/3 h-6 bg-textPrimary/10 rounded-md"></div>
                    <div class="w-2/3 h-4 bg-textSecondary/10 rounded-md"></div>
                    <div class="w-1/2 h-4 bg-textSecondary/10 rounded-md"></div>
                    <div class="mt-4 flex gap-3">
                        <div class="w-24 h-8 bg-primary/10 rounded-lg"></div>
                        <div class="w-24 h-8 bg-borderStrong/10 rounded-lg"></div>
                    </div>
                    <!-- Label -->
                    <div class="absolute bottom-4 right-4 bg-surface/90 backdrop-blur border border-borderLight px-3 py-1.5 rounded-md text-[11px] font-mono text-textSecondary uppercase shadow-sm">
                        Modernized Website
                    </div>
                </div>
            </div>

            <!-- Mobile Mockup Frame -->
            <div class="absolute -bottom-4 lg:-bottom-10 left-4 lg:-left-6 w-[120px] lg:w-[180px] h-[220px] lg:h-[340px] bg-surface rounded-[24px] border-[6px] border-dark shadow-xl overflow-hidden z-20 group hover:-translate-y-2 transition-transform duration-500 delay-75">
                <!-- Mobile notch -->
                <div class="absolute top-0 inset-x-0 h-4 bg-dark rounded-b-xl w-1/2 mx-auto z-30"></div>
                <!-- Mobile Content Placeholder -->
                <div class="p-4 pt-8 lg:p-5 lg:pt-10 flex flex-col gap-3 h-full bg-gradient-to-b from-surfaceMuted to-surface">
                    <div class="w-10 h-10 lg:w-16 lg:h-16 bg-textPrimary/10 rounded-full self-center mb-2"></div>
                    <div class="w-full h-3 lg:h-4 bg-textPrimary/10 rounded-md"></div>
                    <div class="w-4/5 h-2 lg:h-3 bg-textSecondary/10 rounded-md mx-auto"></div>
                    <div class="w-full h-8 lg:h-12 bg-primary/10 rounded-lg mt-auto"></div>
                </div>
            </div>
            
            <!-- Optional subtle decorative elements -->
            <div class="absolute top-1/4 left-1/4 w-3 h-3 rounded-full bg-accent/20 animate-pulse"></div>
            <div class="absolute bottom-1/4 right-1/4 w-4 h-4 rounded-full bg-primary/20 animate-pulse delay-300"></div>
        </div>
    </div>
    
    <div class="w-full flex justify-center text-borderStrong pt-8 lg:absolute lg:bottom-8 z-20">
        <ChevronDown className="w-6 h-6 animate-bounce" />
    </div>
</section>