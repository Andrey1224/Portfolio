---
import { ShieldCheck, Lock } from 'lucide-react';
---

<!-- ========================================== -->
<!-- СЕКЦИЯ 1: HERO (Sticky)                    -->
<!-- ========================================== -->
<section class="sticky-section sticky top-0 w-full h-[100dvh] bg-bgMain flex flex-col justify-center pt-20 overflow-hidden z-10">
    <div class="max-w-[1240px] w-full mx-auto px-6 grid lg:grid-cols-12 gap-12 lg:gap-8 items-center relative">
        
        <!-- Левая колонка: Текст и CTA -->
        <div class="lg:col-span-6 flex flex-col items-start z-20">
            
            <!-- Бейдж "Доступен" -->
            <div class="inline-flex items-center gap-2 px-3 py-2 rounded-full bg-surface border border-borderLight text-textSecondary text-[13px] font-[550] mb-8 shadow-subtle">
                <span class="relative flex h-2 w-2">
                  <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-success opacity-75"></span>
                  <span class="relative inline-flex rounded-full h-2 w-2 bg-success shadow-[0_0_0_4px_rgba(22,163,74,0.12)]"></span>
                </span>
                Available for new projects in Alabama
            </div>

            <!-- Главный заголовок -->
            <h1 class="text-[40px] sm:text-[44px] lg:text-[56px] leading-[1.08] tracking-[-0.035em] font-bold text-textPrimary">
                I Build & Repair High-Performance Websites for Alabama Small Businesses.
            </h1>

            <!-- Подзаголовок -->
            <p class="mt-6 text-[18px] leading-[1.65] text-textSecondary max-w-[540px]">
                I help small businesses fix slow, outdated websites and replace them with fast, reliable systems that capture leads and are easier to maintain.
            </p>

            <!-- Группа кнопок CTA -->
            <div class="mt-10 flex flex-col sm:flex-row gap-4 w-full sm:w-auto">
                <button class="bg-primary hover:bg-primaryHover text-white px-6 py-4 rounded-sm shadow-btn transition-all transform hover:-translate-y-[1px] font-[650] flex items-center justify-center gap-2">
                    Get My Free Technical Audit
                </button>
                <button class="bg-surface hover:bg-primarySoft text-textPrimary border border-borderStrong hover:border-primary px-6 py-4 rounded-sm transition-all font-[650] flex items-center justify-center">
                    View My Work
                </button>
            </div>

            <!-- Строка доверия -->
            <div class="mt-10 flex items-center gap-3 text-[14px] text-textSecondary">
                <div class="w-6 h-6 rounded-full bg-accentSoft text-accent flex items-center justify-center">
                    <ShieldCheck className="w-3.5 h-3.5" />
                </div>
                <span class="font-medium">Trusted by Alabama small businesses to deliver reliable websites and real results.</span>
            </div>
        </div>

        <!-- Правая колонка: Визуал (Мокапы браузера и телефона) -->
        <div class="lg:col-span-6 relative w-full h-[500px] lg:h-[650px] flex items-center justify-center lg:justify-end mt-12 lg:mt-0 z-10">
            
            <!-- Десктопный мокап -->
            <div class="absolute right-0 top-1/2 -translate-y-1/2 w-full max-w-[580px] bg-surface rounded-xl shadow-mockup border border-borderLight overflow-hidden z-10 transition-transform duration-700 hover:-translate-y-[52%]">
                <!-- Шапка браузера -->
                <div class="bg-surfaceMuted border-b border-borderLight px-4 py-3 flex items-center">
                    <div class="flex gap-2 w-1/4">
                        <div class="w-3 h-3 rounded-full bg-borderStrong"></div>
                        <div class="w-3 h-3 rounded-full bg-borderStrong"></div>
                        <div class="w-3 h-3 rounded-full bg-borderStrong"></div>
                    </div>
                    <div class="w-1/2 flex justify-center">
                        <div class="bg-surface border border-borderLight rounded text-[11px] text-textMuted px-4 py-1.5 font-mono flex items-center gap-2">
                            <Lock className="w-3 h-3" /> birmingham-roofing.com
                        </div>
                    </div>
                </div>
                <!-- Контент мокапа (Вайрфрейм сайта локального бизнеса) -->
                <div class="p-8">
                    <div class="flex justify-between items-center mb-8">
                        <div class="w-28 h-6 bg-borderLight rounded"></div>
                        <div class="hidden sm:flex gap-4">
                            <div class="w-12 h-2 bg-surfaceMuted rounded"></div>
                            <div class="w-12 h-2 bg-surfaceMuted rounded"></div>
                            <div class="w-12 h-2 bg-surfaceMuted rounded"></div>
                        </div>
                    </div>
                    <div class="w-3/4 h-8 bg-textPrimary rounded mb-4"></div>
                    <div class="w-1/2 h-8 bg-textPrimary rounded mb-6"></div>
                    <div class="w-2/3 h-3 bg-textMuted rounded mb-3"></div>
                    <div class="w-1/3 h-3 bg-textMuted rounded mb-8"></div>
                    <div class="w-32 h-10 bg-primary rounded-sm mb-12"></div>
                    
                    <div class="grid grid-cols-3 gap-6">
                        <div class="h-24 bg-surfaceMuted rounded border border-borderLight"></div>
                        <div class="h-24 bg-surfaceMuted rounded border border-borderLight"></div>
                        <div class="h-24 bg-surfaceMuted rounded border border-borderLight"></div>
                    </div>
                </div>
            </div>

            <!-- Мобильный мокап -->
            <div class="absolute -bottom-4 lg:bottom-12 -left-4 lg:left-0 w-[180px] h-[380px] bg-surface rounded-[32px] shadow-[0_20px_50px_rgba(0,0,0,0.2)] border-[8px] border-dark overflow-hidden z-20 transition-transform duration-700 hover:-translate-y-2">
                <!-- Вырез "Dynamic Island" -->
                <div class="absolute top-2 left-1/2 -translate-x-1/2 w-14 h-4 bg-dark rounded-full z-30"></div>
                <!-- Контент -->
                <div class="w-full h-full bg-surface pt-12 px-4 flex flex-col gap-4">
                    <div class="w-full h-24 bg-surfaceMuted rounded-lg"></div>
                    <div class="w-3/4 h-4 bg-textPrimary rounded"></div>
                    <div class="w-full h-2 bg-borderLight rounded"></div>
                    <div class="w-5/6 h-2 bg-borderLight rounded"></div>
                    <div class="mt-4 w-full h-10 bg-primary rounded-sm"></div>
                </div>
            </div>

        </div>
    </div>
</section>
