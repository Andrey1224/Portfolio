---
import { ArrowUpRight } from 'lucide-react';
---

<section class="hero-first-screen relative lg:sticky lg:top-[72px] w-full px-4 sm:px-8 pt-28 pb-10 lg:py-0 flex flex-col items-center justify-start lg:justify-center bg-bgMain z-0 overflow-hidden">
	<div class="max-w-[1400px] w-full mx-auto grid lg:grid-cols-12 gap-8 lg:gap-12 items-center">
		<div class="lg:col-span-7 flex flex-col items-start w-full observe-block">
			<div class="stamp-item shadow-brutal-sm delay-100 inline-flex items-center gap-2 px-3 py-1.5 bg-surface brutal-border text-[10px] md:text-[12px] font-mono font-bold uppercase tracking-widest mb-6 lg:mb-8">
				<div class="w-2.5 h-2.5 bg-success brutal-border animate-pulse"></div>
				Available in Alabama
			</div>

			<h1 class="text-fluid-hero font-bold uppercase mb-6 lg:mb-8 flex flex-col items-start w-full">
				<span class="reveal-overflow"><span class="reveal-text delay-100 block">I Build &</span></span>
				<span class="reveal-overflow"><span class="reveal-text delay-200 block text-outline hover:text-primary transition-colors duration-300">Repair</span></span>
				<span class="reveal-overflow"><span class="reveal-text delay-300 block bg-primary text-white px-2 mt-1 w-full sm:w-auto">Websites.</span></span>
			</h1>

			<p class="stamp-item delay-300 text-[16px] md:text-[20px] leading-[1.5] font-[500] text-textSecondary mb-8 lg:mb-10 max-w-xl">
				I help small and mid-sized businesses replace slow, outdated websites with fast, reliable systems that bring in leads — without jargon, handoffs, or disappearing after launch.
			</p>

			<div class="flex flex-col sm:flex-row gap-4 sm:gap-6 w-full sm:w-auto mb-6 lg:mb-10">
				<a href="/audit" class="stamp-item shadow-brutal delay-400 btn-brutal w-full sm:w-auto bg-black text-white brutal-border px-6 sm:px-8 py-4 font-bold uppercase tracking-widest text-[13px] sm:text-[14px] flex justify-center items-center gap-2">
					GET A FREE SITE REVIEW <ArrowUpRight className="w-5 h-5" />
				</a>
				<a href="#work" class="stamp-item shadow-brutal delay-400 btn-brutal w-full sm:w-auto bg-surface text-black brutal-border px-6 sm:px-8 py-4 font-bold uppercase tracking-widest text-[13px] sm:text-[14px] text-center">
					SEE RECENT PROJECTS
				</a>
			</div>

			<div class="stamp-item delay-500 flex flex-wrap items-center gap-x-3 sm:gap-x-4 gap-y-2 text-[10px] md:text-[12px] font-mono font-bold uppercase tracking-widest text-textSecondary">
				<span>Alabama-based</span>
				<span class="w-1.5 h-1.5 bg-primary"></span>
				<span>Direct communication</span>
				<span class="w-1.5 h-1.5 bg-primary"></span>
				<span>Clear timelines</span>
				<span class="w-1.5 h-1.5 bg-primary"></span>
				<span>Post-launch support</span>
			</div>
		</div>

		<div class="observe-block lg:col-span-5 w-full">
			<div class="stamp-item shadow-brutal delay-300 w-full bg-surface brutal-border p-4 lg:p-6 relative h-[230px] sm:h-[350px] lg:h-[450px]">
				<div class="border-b-[3px] border-black pb-3 mb-4 flex gap-2">
					<div class="w-3 h-3 brutal-border rounded-full bg-bgMain"></div>
					<div class="w-3 h-3 brutal-border rounded-full bg-bgMain"></div>
					<div class="w-3 h-3 brutal-border rounded-full bg-bgMain"></div>
				</div>
				<div class="w-3/4 h-6 lg:h-8 bg-black mb-3"></div>
				<div class="w-1/2 h-6 lg:h-8 bg-black mb-6"></div>
				<div class="w-1/3 h-10 lg:h-12 bg-primary brutal-border shadow-brutal-sm mb-6"></div>
				<div class="hidden sm:grid grid-cols-3 gap-4">
					<div class="h-20 lg:h-32 bg-gray-200 brutal-border"></div>
					<div class="h-20 lg:h-32 bg-gray-200 brutal-border"></div>
					<div class="h-20 lg:h-32 bg-gray-200 brutal-border hidden sm:block"></div>
				</div>

				<div class="stamp-item shadow-brutal delay-400 absolute -bottom-4 -right-2 lg:-bottom-10 lg:-left-10 w-[104px] sm:w-[120px] lg:w-[160px] h-[170px] sm:h-[200px] lg:h-[280px] bg-white brutal-border p-3 z-10 flex flex-col hover:-translate-y-4 transition-transform duration-500">
					<div class="w-full h-16 lg:h-24 bg-gray-200 brutal-border mb-3"></div>
					<div class="w-full h-3 lg:h-4 bg-black mb-2"></div>
					<div class="w-2/3 h-3 lg:h-4 bg-black mb-auto"></div>
					<div class="w-full h-8 lg:h-12 bg-primary brutal-border"></div>
				</div>
			</div>
		</div>
	</div>
</section>
