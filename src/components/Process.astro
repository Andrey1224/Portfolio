---
---

<section class="w-full px-4 sm:px-8 py-16 lg:py-24 bg-bgMain brutal-border-b overflow-hidden relative z-10">
	<div class="max-w-[1400px] mx-auto observe-block">
		<span class="text-[12px] font-mono font-bold text-primary uppercase tracking-widest block mb-4">[ 04. The Method ]</span>
		<h2 class="text-fluid-h2 font-bold uppercase mb-8 leading-none">
			<span class="reveal-overflow"><span class="reveal-text block">Clear Process.</span></span><br />
			<span class="reveal-overflow"><span class="reveal-text block">No Guesswork.</span></span>
		</h2>
		<p class="text-[17px] md:text-[22px] text-textSecondary max-w-2xl font-[500] mb-12 md:mb-16">
			From the first audit to post-launch support, you always know what happens next.
		</p>

		<div class="flex flex-col gap-12 md:gap-24 mt-12 md:mt-24 relative z-10">
			<!-- Step 1 -->
			<div class="stamp-item delay-100 flex flex-col md:flex-row items-start md:items-center gap-3 md:gap-12 group">
				<div class="text-[88px] sm:text-[120px] md:text-[180px] lg:text-[220px] font-black leading-[0.75] font-mono text-transparent shrink-0" style="-webkit-text-stroke: clamp(2px, 0.6vw, 4px) #000;">
					01
				</div>
				<div class="w-full border-t-4 md:border-t-8 border-black pt-5 md:pt-6 group-hover:translate-x-0 md:group-hover:translate-x-8 transition-transform duration-300">
					<h3 class="text-[30px] md:text-[48px] font-black uppercase mb-3 text-black tracking-tighter leading-none">Audit</h3>
					<p class="text-[16px] md:text-[20px] text-textSecondary font-[600] max-w-lg">We identify speed, SEO, UX, and technical issues holding your site back.</p>
				</div>
			</div>

			<!-- Step 2 -->
			<div class="stamp-item delay-200 flex flex-col md:flex-row items-start md:items-center gap-3 md:gap-12 group">
				<div class="text-[88px] sm:text-[120px] md:text-[180px] lg:text-[220px] font-black leading-[0.75] font-mono text-transparent shrink-0" style="-webkit-text-stroke: clamp(2px, 0.6vw, 4px) #000;">
					02
				</div>
				<div class="w-full border-t-4 md:border-t-8 border-black pt-5 md:pt-6 group-hover:translate-x-0 md:group-hover:translate-x-8 transition-transform duration-300 relative">
					<div class="absolute -top-[24px] left-0 bg-primary text-white text-[12px] font-bold uppercase px-3 py-1 brutal-border">Core Phase</div>
					<h3 class="text-[30px] md:text-[48px] font-black uppercase mb-3 text-black tracking-tighter leading-none">Build</h3>
					<p class="text-[16px] md:text-[20px] text-textSecondary font-[600] max-w-lg">I rebuild or repair the system around your business goals.</p>
				</div>
			</div>

			<!-- Step 3 -->
			<div class="stamp-item delay-300 flex flex-col md:flex-row items-start md:items-center gap-3 md:gap-12 group">
				<div class="text-[88px] sm:text-[120px] md:text-[180px] lg:text-[220px] font-black leading-[0.75] font-mono text-transparent shrink-0" style="-webkit-text-stroke: clamp(2px, 0.6vw, 4px) #000;">
					03
				</div>
				<div class="w-full border-t-4 md:border-t-8 border-black pt-5 md:pt-6 group-hover:translate-x-0 md:group-hover:translate-x-8 transition-transform duration-300">
					<h3 class="text-[30px] md:text-[48px] font-black uppercase mb-3 text-black tracking-tighter leading-none">Launch</h3>
					<p class="text-[16px] md:text-[20px] text-textSecondary font-[600] max-w-lg">We test, optimize, and go live without guesswork.</p>
				</div>
			</div>

			<!-- Step 4 -->
			<div class="stamp-item delay-400 flex flex-col md:flex-row items-start md:items-center gap-3 md:gap-12 group">
				<div class="text-[88px] sm:text-[120px] md:text-[180px] lg:text-[220px] font-black leading-[0.75] font-mono text-transparent shrink-0" style="-webkit-text-stroke: clamp(2px, 0.6vw, 4px) #000;">
					04
				</div>
				<div class="w-full border-t-4 md:border-t-8 border-black pt-5 md:pt-6 group-hover:translate-x-0 md:group-hover:translate-x-8 transition-transform duration-300 relative">
					<div class="absolute -top-[24px] left-0 bg-success text-white text-[12px] font-bold uppercase px-3 py-1 brutal-border">Always ON</div>
					<h3 class="text-[30px] md:text-[48px] font-black uppercase mb-3 text-black tracking-tighter leading-none">Support</h3>
					<p class="text-[16px] md:text-[20px] text-textSecondary font-[600] max-w-lg">I stay available after launch so the site keeps working.</p>
				</div>
			</div>
		</div>
	</div>
</section>
