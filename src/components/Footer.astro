---
import { Mail, Phone } from 'lucide-react';
---

<footer class="w-full bg-black text-white pt-16 pb-8 px-4 sm:px-8 border-t-[12px] border-black relative z-10">
	<div class="max-w-[1400px] mx-auto">
		<div class="flex flex-col lg:flex-row justify-between items-center lg:items-end mb-16 pb-16 border-b-2 border-gray-800 gap-10">
			<div class="text-center lg:text-left">
				<h3 class="text-[24px] md:text-[32px] font-bold uppercase mb-4">Andrii Web Developer</h3>
				<p class="text-[14px] md:text-[16px] text-gray-400 font-[500] leading-relaxed max-w-[400px] mx-auto lg:mx-0">
					Serving Alabama small businesses: Birmingham • Huntsville • Mobile • Montgomery
				</p>
			</div>

			<div class="flex flex-col sm:flex-row gap-6 lg:gap-10">
				<a href="mailto:hello@andrii.dev" class="flex items-center justify-center gap-3 text-[16px] font-bold uppercase hover:text-primary transition-colors">
					<Mail className="w-6 h-6" /> hello@andrii.dev
				</a>
				<a href="tel:2565550198" class="flex items-center justify-center gap-3 text-[16px] font-bold uppercase hover:text-primary transition-colors">
					<Phone className="w-6 h-6" /> (256) 555-0198
				</a>
			</div>
		</div>

		<div class="flex flex-col sm:flex-row justify-between items-center text-[12px] font-mono text-gray-600 uppercase tracking-widest gap-4">
			<span>&copy; 2026 Andrii Web Developer. All rights reserved.</span>
			<span>System Operational</span>
		</div>
	</div>
</footer>
