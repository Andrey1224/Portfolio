---
import { Mail, Phone, Send } from 'lucide-react';
---

<footer class="w-full bg-black text-white pt-16 pb-8 px-4 sm:px-8 border-t-[12px] border-black relative z-10">
	<div class="max-w-[1400px] mx-auto">
		<div class="flex flex-col lg:flex-row justify-between items-center lg:items-end mb-16 pb-16 border-b-2 border-gray-800 gap-10">
			<div class="text-center lg:text-left">
				<h3 class="text-[24px] md:text-[32px] font-bold uppercase mb-4">Andrii Web Developer</h3>
				<p class="text-[14px] md:text-[16px] text-gray-400 font-[500] leading-relaxed max-w-[400px] mx-auto lg:mx-0">
					Serving Alabama small businesses: Birmingham • Huntsville • Mobile • Montgomery
				</p>
			</div>

			<div class="flex flex-col items-center lg:items-end gap-8">
				<div class="flex flex-col sm:flex-row gap-6 lg:gap-10">
					<a href="mailto:hello@andrii.dev" class="flex items-center justify-center gap-3 text-[16px] font-bold uppercase hover:text-primary transition-colors">
						<Mail className="w-6 h-6" /> hello@andrii.dev
					</a>
					<a href="tel:2565550198" class="flex items-center justify-center gap-3 text-[16px] font-bold uppercase hover:text-primary transition-colors">
						<Phone className="w-6 h-6" /> (256) 555-0198
					</a>
				</div>
				
				<!-- Social Links -->
				<div class="flex flex-wrap gap-4 justify-center lg:justify-end">
					<a href="#" aria-label="LinkedIn" class="w-12 h-12 flex items-center justify-center bg-black text-white border-[3px] border-white shadow-[4px_4px_0_0_#FFF] hover:-translate-y-1 hover:-translate-x-1 hover:bg-white hover:text-black hover:shadow-[6px_6px_0_0_#0A66C2] transition-all">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
					</a>
					<a href="#" aria-label="GitHub" class="w-12 h-12 flex items-center justify-center bg-black text-white border-[3px] border-white shadow-[4px_4px_0_0_#FFF] hover:-translate-y-1 hover:-translate-x-1 hover:bg-white hover:text-black hover:shadow-[6px_6px_0_0_#8A2BE2] transition-all">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.2c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
					</a>
					<a href="#" aria-label="Instagram" class="w-12 h-12 flex items-center justify-center bg-black text-white border-[3px] border-white shadow-[4px_4px_0_0_#FFF] hover:-translate-y-1 hover:-translate-x-1 hover:bg-white hover:text-black hover:shadow-[6px_6px_0_0_#E1306C] transition-all">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
					</a>
					<a href="#" aria-label="Telegram" class="w-12 h-12 flex items-center justify-center bg-black text-white border-[3px] border-white shadow-[4px_4px_0_0_#FFF] hover:-translate-y-1 hover:-translate-x-1 hover:bg-white hover:text-black hover:shadow-[6px_6px_0_0_#229ED9] transition-all">
						<Send className="w-6 h-6" />
					</a>
					<a href="#" aria-label="Facebook" class="w-12 h-12 flex items-center justify-center bg-black text-white border-[3px] border-white shadow-[4px_4px_0_0_#FFF] hover:-translate-y-1 hover:-translate-x-1 hover:bg-white hover:text-black hover:shadow-[6px_6px_0_0_#1877F2] transition-all">
						<svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
					</a>
				</div>
			</div>
		</div>

		<div class="flex flex-col sm:flex-row justify-between items-center text-[12px] font-mono text-gray-600 uppercase tracking-widest gap-4">
			<span>&copy; 2026 Andrii Web Developer. All rights reserved.</span>
			<span>System Operational</span>
		</div>
	</div>
</footer>
