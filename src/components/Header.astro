---
import { ArrowRight, Menu, Zap } from 'lucide-react';
---

<header class="fixed top-0 left-0 w-full z-[100] bg-surface brutal-border-b h-[72px] flex justify-between items-stretch">
	<a href="/" class="flex items-center gap-3 px-5 sm:px-6 brutal-border-r bg-primary text-white font-bold uppercase tracking-widest text-[16px]">
		<Zap className="w-5 h-5 fill-white" />
		<span class="hidden sm:inline">Andrii.Dev</span>
		<span class="sm:hidden">Andrii</span>
	</a>

	<nav class="hidden md:flex items-stretch font-bold text-[14px] uppercase tracking-widest">
		<a href="/#work" class="flex items-center px-8 brutal-border-r hover:bg-black hover:text-white transition-colors">Work</a>
		<a href="/#services" class="flex items-center px-8 brutal-border-r hover:bg-black hover:text-white transition-colors">Services</a>
		<a href="/#about" class="flex items-center px-8 brutal-border-r hover:bg-black hover:text-white transition-colors">About</a>
	</nav>

	<div class="flex items-stretch ml-auto">
		<div class="hidden lg:flex items-center gap-2 px-8 brutal-border-l font-mono text-[12px] uppercase tracking-widest text-textPrimary font-bold">
			<div class="w-3 h-3 bg-success border-2 border-black"></div>
			Alabama Based
		</div>
		<a href="/audit" class="hidden md:flex bg-black text-white px-8 font-bold text-[14px] uppercase tracking-widest hover:bg-primary transition-colors items-center gap-2">
			Request Audit <ArrowRight className="w-5 h-5" />
		</a>
		<details class="md:hidden relative">
			<summary class="h-full flex bg-black text-white px-6 items-center justify-center cursor-pointer" aria-label="Open mobile menu">
				<Menu className="w-6 h-6" />
			</summary>
			<div class="absolute right-0 top-full w-screen bg-surface text-black border-b-[3px] border-black shadow-[0_8px_0_0_#000]">
				<nav class="grid font-bold text-[13px] uppercase tracking-widest">
					<a href="/#work" class="px-5 py-4 border-b-2 border-black hover:bg-black hover:text-white transition-colors">Work</a>
					<a href="/#services" class="px-5 py-4 border-b-2 border-black hover:bg-black hover:text-white transition-colors">Services</a>
					<a href="/#about" class="px-5 py-4 border-b-2 border-black hover:bg-black hover:text-white transition-colors">About</a>
					<a href="/#faq" class="px-5 py-4 border-b-2 border-black hover:bg-black hover:text-white transition-colors">FAQ</a>
					<a href="/audit" class="px-5 py-4 bg-primary text-white flex items-center justify-between">
						Request Audit <ArrowRight className="w-5 h-5" />
					</a>
				</nav>
			</div>
		</details>
	</div>
</header>
