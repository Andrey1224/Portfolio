---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Request a Site Audit — Andrii | Alabama Web Developer">
	<Header />

	<main class="w-full min-h-screen bg-bgMain pt-24 pb-32 px-4 sm:px-8">
		<div class="max-w-[860px] mx-auto">

			<!-- Page Header -->
			<div class="observe-block mb-12 lg:mb-16">
				<span class="stamp-item shadow-brutal-sm delay-100 inline-block text-[11px] font-mono font-bold uppercase tracking-widest bg-surface brutal-border px-3 py-1.5 mb-6">
					[ INTAKE FORM — SITE DIAGNOSTIC ]
				</span>

				<h1 class="text-fluid-h2 font-black uppercase leading-none mb-6">
					<span class="reveal-overflow"><span class="reveal-text delay-100 block">Request a</span></span>
					<span class="reveal-overflow"><span class="reveal-text delay-200 block text-outline">Free Site</span></span>
					<span class="reveal-overflow"><span class="reveal-text delay-300 block bg-primary text-white px-2 w-full sm:w-auto inline-block">Audit.</span></span>
				</h1>

				<p class="stamp-item delay-300 text-[16px] md:text-[18px] text-textSecondary font-[500] leading-relaxed max-w-xl">
					Fill in the form below. I'll manually review your current setup and reply with a clear, honest assessment within <strong class="text-black font-black">24–48 hours</strong> — no pitch, no pressure.
				</p>
			</div>

			<!-- Form Card -->
			<div class="stamp-item delay-200 bg-surface border-2 border-black shadow-[8px_8px_0_0_#000] p-8 lg:p-12 observe-block" id="audit-form-wrapper">

				<!-- Form Header Bar -->
				<div class="flex items-center gap-3 border-b-2 border-black pb-4 mb-10">
					<div class="w-2.5 h-2.5 bg-success border border-black"></div>
					<div class="w-2.5 h-2.5 bg-warning border border-black"></div>
					<div class="w-2.5 h-2.5 bg-[#EF4444] border border-black"></div>
					<span class="font-mono text-[11px] font-bold uppercase tracking-widest text-textSecondary ml-2">DIAGNOSTIC_REQUEST_FORM.EXE</span>
				</div>

				<form id="audit-form" novalidate>
					<!-- Honeypot -->
					<input type="text" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
					<input type="hidden" name="access_key" value={import.meta.env.PUBLIC_WEB3FORMS_KEY} />
					<input type="hidden" name="subject" value="New Site Audit Request — nepod77@gmail.com" />
					<input type="hidden" name="from_name" value="Andrii Portfolio" />

					<div class="grid sm:grid-cols-2 gap-6 mb-8">
						<!-- Name -->
						<div class="flex flex-col gap-2">
							<label for="name" class="font-mono text-[11px] font-bold uppercase tracking-widest text-black">[ FIELD: NAME ] <span class="text-[#EF4444]">*</span></label>
							<input
								type="text"
								id="name"
								name="name"
								required
								placeholder="John Smith"
								class="w-full bg-bgMain border-2 border-black px-4 py-3 font-sans text-[15px] font-[500] text-black placeholder:text-textSecondary focus:outline-none focus-visible:ring-0 focus:border-primary transition-colors"
							/>
						</div>

						<!-- Business Name -->
						<div class="flex flex-col gap-2">
							<label for="business" class="font-mono text-[11px] font-bold uppercase tracking-widest text-black">[ FIELD: BUSINESS NAME ] <span class="text-textSecondary font-normal normal-case tracking-normal">(optional)</span></label>
							<input
								type="text"
								id="business"
								name="business_name"
								placeholder="Smith & Co Plumbing"
								class="w-full bg-bgMain border-2 border-black px-4 py-3 font-sans text-[15px] font-[500] text-black placeholder:text-textSecondary focus:outline-none focus-visible:ring-0 focus:border-primary transition-colors"
							/>
						</div>
					</div>

					<div class="grid sm:grid-cols-2 gap-6 mb-8">
						<!-- Email -->
						<div class="flex flex-col gap-2">
							<label for="email" class="font-mono text-[11px] font-bold uppercase tracking-widest text-black">[ FIELD: EMAIL ] <span class="text-[#EF4444]">*</span></label>
							<input
								type="email"
								id="email"
								name="email"
								required
								placeholder="john@smithplumbing.com"
								class="w-full bg-bgMain border-2 border-black px-4 py-3 font-sans text-[15px] font-[500] text-black placeholder:text-textSecondary focus:outline-none focus-visible:ring-0 focus:border-primary transition-colors"
							/>
						</div>

						<!-- Phone -->
						<div class="flex flex-col gap-2">
							<label for="phone" class="font-mono text-[11px] font-bold uppercase tracking-widest text-black">[ FIELD: PHONE ] <span class="text-textSecondary font-normal normal-case tracking-normal">(optional)</span></label>
							<input
								type="tel"
								id="phone"
								name="phone"
								placeholder="(256) 555-0100"
								class="w-full bg-bgMain border-2 border-black px-4 py-3 font-sans text-[15px] font-[500] text-black placeholder:text-textSecondary focus:outline-none focus-visible:ring-0 focus:border-primary transition-colors"
							/>
						</div>
					</div>

					<!-- Website URL (optional) -->
					<div class="flex flex-col gap-2 mb-10">
						<label for="url" class="font-mono text-[11px] font-bold uppercase tracking-widest text-black">[ FIELD: CURRENT WEBSITE URL ] <span class="text-textSecondary font-normal normal-case tracking-normal">(optional — leave blank if you need a new site)</span></label>
						<input
							type="url"
							id="url"
							name="website_url"
							placeholder="https://yoursite.com"
							class="w-full bg-bgMain border-2 border-black px-4 py-3 font-sans text-[15px] font-[500] text-black placeholder:text-textSecondary focus:outline-none focus-visible:ring-0 focus:border-primary transition-colors"
						/>
					</div>

					<!-- What do you need help with? -->
					<div class="mb-10">
						<fieldset>
							<legend class="font-mono text-[11px] font-bold uppercase tracking-widest text-black mb-4">[ FIELD: WHAT DO YOU NEED HELP WITH? ] <span class="text-[#EF4444]">*</span></legend>
							<div class="grid sm:grid-cols-2 gap-3" id="help-checkboxes">
								{[
									{ id: 'help-slow',     label: 'My site loads too slowly',          value: 'Slow site speed' },
									{ id: 'help-outdated', label: 'My site looks outdated',            value: 'Outdated design' },
									{ id: 'help-new',      label: 'I need a completely new website',  value: 'New website build' },
									{ id: 'help-mobile',   label: "My site doesn't work on mobile",   value: 'Mobile issues' },
									{ id: 'help-leads',    label: 'Forms / calls / leads not working',value: 'Lead capture issues' },
									{ id: 'help-seo',      label: 'I need local SEO help',            value: 'Local SEO' },
									{ id: 'help-support',  label: 'I need ongoing maintenance',        value: 'Ongoing support' },
									{ id: 'help-other',    label: "Not sure — I just know it's broken", value: 'Not sure' },
								].map(({ id, label, value }) => (
									<label for={id} class="brutal-checkbox flex items-start gap-3 border-2 border-black bg-bgMain px-4 py-3 cursor-pointer hover:bg-warning hover:border-black transition-colors duration-150 select-none group">
										<input type="checkbox" id={id} name="help_with" value={value} class="sr-only peer" />
										<span class="flex-shrink-0 w-5 h-5 border-2 border-black bg-surface mt-0.5 flex items-center justify-center peer-checked:bg-black">
											<svg class="hidden peer-checked:block w-3 h-3 text-white" viewBox="0 0 12 12" fill="none">
												<polyline points="1,6 5,10 11,2" stroke="currentColor" stroke-width="2.5" stroke-linecap="square"/>
											</svg>
										</span>
										<span class="text-[14px] font-[600] leading-tight">{label}</span>
									</label>
								))}
							</div>
							<p id="help-error" class="hidden mt-3 font-mono text-[11px] text-[#EF4444] font-bold uppercase">[ ERROR: SELECT AT LEAST ONE OPTION ]</p>
						</fieldset>
					</div>

					<div class="grid sm:grid-cols-2 gap-6 mb-10">
						<!-- Timeline -->
						<div class="flex flex-col gap-2">
							<label for="timeline" class="font-mono text-[11px] font-bold uppercase tracking-widest text-black">[ FIELD: TIMELINE ] <span class="text-textSecondary font-normal normal-case tracking-normal">(optional)</span></label>
							<div class="relative">
								<select
									id="timeline"
									name="timeline"
									class="w-full appearance-none bg-bgMain border-2 border-black px-4 py-3 font-sans text-[15px] font-[500] text-black focus:outline-none focus:border-primary transition-colors cursor-pointer"
								>
									<option value="">— Select timeline —</option>
									<option value="ASAP">As soon as possible</option>
									<option value="1-month">Within 1 month</option>
									<option value="1-3-months">1–3 months</option>
									<option value="flexible">Flexible / not sure yet</option>
								</select>
								<span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 font-mono text-[11px] font-black">▼</span>
							</div>
						</div>

						<!-- Budget -->
						<div class="flex flex-col gap-2">
							<label for="budget" class="font-mono text-[11px] font-bold uppercase tracking-widest text-black">[ FIELD: BUDGET RANGE ] <span class="text-textSecondary font-normal normal-case tracking-normal">(optional)</span></label>
							<div class="relative">
								<select
									id="budget"
									name="budget"
									class="w-full appearance-none bg-bgMain border-2 border-black px-4 py-3 font-sans text-[15px] font-[500] text-black focus:outline-none focus:border-primary transition-colors cursor-pointer"
								>
									<option value="">— Select range —</option>
									<option value="under-500">Under $500</option>
									<option value="500-1500">$500 – $1,500</option>
									<option value="1500-5000">$1,500 – $5,000</option>
									<option value="5000-plus">$5,000+</option>
									<option value="not-sure">Not sure yet</option>
								</select>
								<span class="pointer-events-none absolute right-4 top-1/2 -translate-y-1/2 font-mono text-[11px] font-black">▼</span>
							</div>
						</div>
					</div>

					<!-- Message -->
					<div class="flex flex-col gap-2 mb-10">
						<label for="message" class="font-mono text-[11px] font-bold uppercase tracking-widest text-black">[ FIELD: ADDITIONAL NOTES ] <span class="text-textSecondary font-normal normal-case tracking-normal">(optional)</span></label>
						<textarea
							id="message"
							name="message"
							rows="4"
							placeholder="Any details that help me understand your situation..."
							class="w-full bg-bgMain border-2 border-black px-4 py-3 font-sans text-[15px] font-[500] text-black placeholder:text-textSecondary focus:outline-none focus-visible:ring-0 focus:border-primary transition-colors resize-none"
						></textarea>
					</div>

					<!-- Submit -->
					<div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
						<button
							type="submit"
							id="submit-btn"
							class="btn-brutal shadow-brutal bg-black text-white brutal-border px-8 py-4 font-black uppercase tracking-widest text-[14px] flex items-center gap-3 transition-all"
						>
							<span id="submit-label">[ START SITE DIAGNOSTIC ]</span>
							<svg id="submit-spinner" class="hidden w-5 h-5 animate-spin" viewBox="0 0 24 24" fill="none">
								<circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" stroke-dasharray="30 70" />
							</svg>
						</button>
						<p class="font-mono text-[11px] text-textSecondary uppercase tracking-widest">No pitch. Response in 24–48h.</p>
					</div>

					<!-- Error message -->
					<div id="form-error" class="hidden mt-6 border-2 border-[#EF4444] bg-[#EF4444]/10 px-5 py-4">
						<p class="font-mono text-[12px] font-bold text-[#EF4444] uppercase">[ TRANSMISSION ERROR ] — Please check your fields and try again.</p>
					</div>
				</form>

				<!-- Success State (hidden by default) -->
				<div id="audit-success" class="hidden text-center py-8">
					<span class="inline-block font-mono text-[11px] font-bold uppercase tracking-widest bg-success text-white px-3 py-1.5 border-2 border-black mb-6">[ REQUEST RECEIVED ]</span>
					<h2 class="text-[32px] sm:text-[48px] font-black uppercase leading-none mb-4">Case Filed.</h2>
					<p class="text-[16px] sm:text-[18px] text-textSecondary font-[500] max-w-md mx-auto mb-8">
						I'll manually review your site and reply within <strong class="text-black font-black">24–48 hours</strong> with a clear, honest assessment.
					</p>
					<a href="/" class="btn-brutal shadow-brutal inline-flex items-center gap-2 bg-black text-white brutal-border px-6 py-3 font-bold uppercase tracking-widest text-[13px]">
						← Back to Base
					</a>
				</div>
			</div>

			<!-- Bottom trust line -->
			<p class="mt-8 font-mono text-[11px] text-textSecondary uppercase tracking-widest text-center">
				Alabama-based · Direct communication · No agencies, no middlemen
			</p>

		</div>
	</main>

	<Footer />
</Layout>

<style>
	/* Peer-checked trick needs the SVG to be part of the label context */
	.brutal-checkbox input:checked ~ span > svg {
		display: block;
	}
	.brutal-checkbox input:checked + span {
		background-color: #000;
	}
</style>

<script>
	const form = document.getElementById('audit-form') as HTMLFormElement | null;
	const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement | null;
	const submitLabel = document.getElementById('submit-label');
	const submitSpinner = document.getElementById('submit-spinner');
	const successBlock = document.getElementById('audit-success');
	const formError = document.getElementById('form-error');
	const helpError = document.getElementById('help-error');

	// Helper: show field error
	function setFieldError(fieldId: string, show: boolean) {
		const input = document.getElementById(fieldId) as HTMLInputElement | null;
		const errorId = `${fieldId}-error`;
		let errorEl = document.getElementById(errorId);

		if (!input) return;

		if (show) {
			input.classList.add('border-[#EF4444]');
			input.classList.remove('border-black');
			if (!errorEl) {
				errorEl = document.createElement('p');
				errorEl.id = errorId;
				errorEl.className = 'font-mono text-[11px] text-[#EF4444] font-bold uppercase mt-1';
				errorEl.textContent = '[ REQUIRED — FIELD CANNOT BE EMPTY ]';
				input.parentElement?.appendChild(errorEl);
			}
			errorEl.classList.remove('hidden');
		} else {
			input.classList.remove('border-[#EF4444]');
			input.classList.add('border-black');
			if (errorEl) errorEl.classList.add('hidden');
		}
	}

	// Clear errors on input
	['name', 'email'].forEach((id) => {
		document.getElementById(id)?.addEventListener('input', () => setFieldError(id, false));
	});

	form?.addEventListener('submit', async (e) => {
		e.preventDefault();
		let hasErrors = false;

		// Validate Name
		const nameVal = (document.getElementById('name') as HTMLInputElement)?.value.trim();
		if (!nameVal) {
			setFieldError('name', true);
			hasErrors = true;
		} else {
			setFieldError('name', false);
		}

		// Validate Email
		const emailEl = document.getElementById('email') as HTMLInputElement;
		const emailVal = emailEl?.value.trim();
		const emailValid = /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(emailVal);
		if (!emailVal || !emailValid) {
			setFieldError('email', true);
			if (emailEl) {
				let errEl = document.getElementById('email-error');
				if (errEl) {
					errEl.textContent = !emailVal
						? '[ REQUIRED — FIELD CANNOT BE EMPTY ]'
						: '[ INVALID EMAIL FORMAT ]';
				}
			}
			hasErrors = true;
		} else {
			setFieldError('email', false);
		}

		// Validate Checkboxes
		const checked = form.querySelectorAll('input[name="help_with"]:checked');
		if (checked.length === 0) {
			helpError?.classList.remove('hidden');
			hasErrors = true;
		} else {
			helpError?.classList.add('hidden');
		}

		if (hasErrors) {
			// Scroll to first error
			const firstError = form.querySelector('.border-\\[\\#EF4444\\], #help-error:not(.hidden)');
			firstError?.scrollIntoView({ behavior: 'smooth', block: 'center' });
			return;
		}

		formError?.classList.add('hidden');

		// Loading state
		if (submitBtn) submitBtn.disabled = true;
		if (submitLabel) submitLabel.textContent = '[ SENDING... ]';
		submitSpinner?.classList.remove('hidden');

		const data = new FormData(form);

		try {
			const res = await fetch('https://api.web3forms.com/submit', {
				method: 'POST',
				body: data,
			});
			const json = await res.json();

			if (json.success) {
				form.classList.add('hidden');
				successBlock?.classList.remove('hidden');
				successBlock?.scrollIntoView({ behavior: 'smooth', block: 'start' });
			} else {
				throw new Error('Submission failed');
			}
		} catch {
			formError?.classList.remove('hidden');
			if (submitBtn) submitBtn.disabled = false;
			if (submitLabel) submitLabel.textContent = '[ START SITE DIAGNOSTIC ]';
			submitSpinner?.classList.add('hidden');
		}
	});
</script>
